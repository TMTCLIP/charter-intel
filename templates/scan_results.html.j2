<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ state }} Charter Market Scan — {{ date_str }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      font-size: 13px;
      color: #1a1a1a;
      background: #f8f8f8;
      padding: 24px;
    }

    h1 {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .meta {
      font-size: 11px;
      color: #666;
      margin-bottom: 20px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
    }

    thead th {
      background: #1e293b;
      color: #e2e8f0;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .05em;
      padding: 10px 12px;
      text-align: left;
      white-space: nowrap;
    }
    thead th.right { text-align: right; }
    thead th.center { text-align: center; }

    tbody tr { border-bottom: 1px solid #e5e7eb; }
    tbody tr:last-child { border-bottom: none; }

    td {
      padding: 9px 12px;
      vertical-align: middle;
    }
    td.right  { text-align: right; }
    td.center { text-align: center; }
    td.rank   { font-weight: 700; color: #64748b; width: 36px; }
    td.score  { font-weight: 700; font-size: 14px; width: 54px; }
    td.city   { font-weight: 600; min-width: 120px; }
    td.snap   { color: #374151; max-width: 280px; }
    td.tensions { color: #6b7280; font-size: 11px; max-width: 180px; }

    /* Tier row colouring */
    tr.tier-HIGH_PRIORITY  { background: #f0fdf4; }
    tr.tier-STRONG         { background: #eff6ff; }
    tr.tier-MODERATE       { background: #fefce8; }
    tr.tier-WATCHLIST      { background: #fff7ed; }
    tr.tier-AVOID          { background: #fef2f2; }

    /* Tier badge */
    .tier-badge {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 9999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .04em;
      white-space: nowrap;
    }
    .tier-HIGH_PRIORITY  .tier-badge { background: #22c55e; color: #fff; }
    .tier-STRONG         .tier-badge { background: #3b82f6; color: #fff; }
    .tier-MODERATE       .tier-badge { background: #eab308; color: #fff; }
    .tier-WATCHLIST      .tier-badge { background: #f97316; color: #fff; }
    .tier-AVOID          .tier-badge { background: #ef4444; color: #fff; }

    /* Deep review badge */
    .dr-badge {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      white-space: nowrap;
    }
    .dr-strong_recommendation { background: #fee2e2; color: #991b1b; }
    .dr-recommended            { background: #ffedd5; color: #9a3412; }
    .dr-optional_review        { background: #e5e7eb; color: #374151; }

    .tensions-list { list-style: none; }
    .tensions-list li::before { content: "· "; color: #9ca3af; }

    footer {
      margin-top: 16px;
      font-size: 11px;
      color: #9ca3af;
    }

    @media print {
      body { background: #fff; padding: 0; font-size: 11px; }
      table { box-shadow: none; }
      thead th { background: #1e293b !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      tr.tier-HIGH_PRIORITY,
      tr.tier-STRONG,
      tr.tier-MODERATE,
      tr.tier-WATCHLIST,
      tr.tier-AVOID { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .tier-badge, .dr-badge { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
  </style>
</head>
<body>

  <h1>{{ state }} Charter Market Scan — {{ preset | title }} Preset</h1>
  <p class="meta">
    {{ city_count }} communities · ranked by composite score · generated {{ generated_at[:10] }}
  </p>

  <table>
    <thead>
      <tr>
        <th class="center">Rank</th>
        <th>City</th>
        <th class="right">Score</th>
        <th>Tier</th>
        <th>Snapshot</th>
        <th>Signal Tensions</th>
        <th class="center">Deep Review</th>
      </tr>
    </thead>
    <tbody>
      {% for r in results %}
      <tr class="tier-{{ r.tier or 'MODERATE' }}">
        <td class="rank center">{{ r.rank }}</td>
        <td class="city">{{ r.city }}</td>
        <td class="score right">{{ "%.1f"|format(r.composite) if r.composite is not none else "—" }}</td>
        <td>
          <span class="tier-badge">{{ (r.tier or "—") | replace("_", " ") }}</span>
        </td>
        <td class="snap">{{ r.one_line_snapshot or "—" }}</td>
        <td class="tensions">
          {% if r.signal_tensions %}
            <ul class="tensions-list">
              {% for t in r.signal_tensions %}
                <li>{{ t }}</li>
              {% endfor %}
            </ul>
          {% else %}
            —
          {% endif %}
        </td>
        <td class="center">
          {% set dr = r.deep_review_level or "" %}
          {% if dr == "strong_recommendation" %}
            <span class="dr-badge dr-strong_recommendation">Strong</span>
          {% elif dr == "recommended" %}
            <span class="dr-badge dr-recommended">Recommended</span>
          {% elif dr == "optional_review" %}
            <span class="dr-badge dr-optional_review">Optional</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <footer>
    Scan mode · composite scores from S5 · no audit pass · weights uncalibrated.
    Deep review badge reflects tier only — not a final recommendation.
  </footer>

</body>
</html>
