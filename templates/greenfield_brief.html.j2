<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ brief.community_name | e }}, {{ brief.state | e }} — Emerging Market Brief</title>
  <!-- No external font CDN — offline-safe system stacks throughout -->
  <style>
    :root {
      --bg-primary:    #0d1117;
      --bg-secondary:  #161b22;
      --bg-card:       #1c2128;
      --bg-elevated:   #22272e;
      --border-subtle: rgba(255,255,255,0.08);
      --border-muted:  rgba(255,255,255,0.15);
      --text-primary:  #e6edf3;
      --text-secondary:#8b949e;
      --text-muted:    #6e7681;
      --accent-green:  #3fb950;
      --accent-yellow: #d29922;
      --accent-red:    #f85149;
      --accent-blue:   #58a6ff;
      --accent-orange: #f0883e;
      --score-green:      #3fb950;
      --score-green-bg:   rgba(63,185,80,0.12);
      --score-yellow:     #d29922;
      --score-yellow-bg:  rgba(210,153,34,0.12);
      --score-red:        #f85149;
      --score-red-bg:     rgba(248,81,73,0.12);
      --sidebar-width: 260px;
      /* Offline-safe font stacks */
      --font-sans:  -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      --font-mono:  ui-monospace, 'Cascadia Code', 'SF Mono', 'Fira Code', Menlo, Consolas, 'Courier New', monospace;
      --font-serif: Georgia, 'Times New Roman', serif;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes scaleIn {
      from { transform: scale(0.92); opacity: 0; }
      to   { transform: scale(1);    opacity: 1; }
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 1.6;
      color: var(--text-primary);
      background: var(--bg-primary);
    }

    /* ── Page layout ── */
    .page-shell {
      display: flex;
      max-width: 1140px;
      margin: 0 auto;
      min-height: 100vh;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: var(--sidebar-width);
      flex-shrink: 0;
      background: var(--bg-secondary);
      border-right: 1px solid var(--border-subtle);
      padding: 28px 20px 40px;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    .sb-wordmark {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .sb-community {
      font-family: var(--font-serif);
      font-size: 22px;
      line-height: 1.2;
      color: var(--text-primary);
    }

    .sb-state {
      display: block;
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 300;
      color: var(--text-secondary);
      margin-top: 4px;
    }

    /* ── Emerging Market badge (greenfield-only) ── */
    .emerging-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: 20px;
      background: rgba(88,166,255,0.12);
      border: 1px solid rgba(88,166,255,0.3);
      color: var(--accent-blue);
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      width: fit-content;
    }

    .sb-tagline {
      font-size: 11px;
      color: var(--text-secondary);
      font-style: italic;
      line-height: 1.55;
      border-left: 2px solid var(--border-muted);
      padding-left: 10px;
    }

    .sb-score-block {
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 10px;
      padding: 16px;
      animation: scaleIn 0.4s ease both;
    }

    .sb-score-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .sb-score-num {
      font-family: var(--font-serif);
      font-size: 52px;
      line-height: 1;
      letter-spacing: -1px;
    }

    .sb-score-max {
      font-size: 18px;
      font-family: var(--font-sans);
      font-weight: 300;
      color: var(--text-muted);
    }

    .sb-tier {
      font-size: 11px;
      color: var(--text-secondary);
      margin-top: 8px;
    }

    .sb-score-green  { color: var(--score-green); }
    .sb-score-yellow { color: var(--score-yellow); }
    .sb-score-red    { color: var(--score-red); }

    .sb-badges { display: flex; flex-direction: column; gap: 6px; }

    .sb-through {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .sb-nav-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 0 8px;
      margin-bottom: 4px;
    }

    .sb-nav {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .sb-nav a {
      display: block;
      padding: 5px 8px;
      border-radius: 5px;
      color: var(--text-secondary);
      font-size: 12px;
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
    }

    .sb-nav a:hover {
      background: var(--bg-elevated);
      color: var(--text-primary);
    }

    /* ── Main content ── */
    .main-content {
      flex: 1;
      min-width: 0;
      padding: 32px 40px 72px;
    }

    .section {
      margin-top: 36px;
      animation: fadeIn 0.35s ease both;
    }

    .section-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 14px;
      padding-bottom: 7px;
      border-bottom: 1px solid var(--border-subtle);
    }

    /* ── Pills ── */
    .pill {
      display: inline-block;
      border-radius: 999px;
      padding: 3px 12px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    .pill-green  { background: var(--score-green-bg);  color: var(--score-green);  border: 1px solid rgba(63,185,80,0.3); }
    .pill-yellow { background: var(--score-yellow-bg); color: var(--score-yellow); border: 1px solid rgba(210,153,34,0.3); }
    .pill-red    { background: var(--score-red-bg);    color: var(--score-red);    border: 1px solid rgba(248,81,73,0.3); }

    /* ── Confidence badges ── */
    .conf {
      display: inline-block;
      border-radius: 999px;
      padding: 2px 10px;
      font-size: 11px;
      font-family: var(--font-mono);
    }

    .conf-high     { background: rgba(88,166,255,0.12); color: var(--accent-blue);   border: 1px solid rgba(88,166,255,0.25); font-weight: 600; }
    .conf-moderate { background: transparent;           color: var(--text-secondary); border: 1px solid var(--border-muted);  font-weight: 600; }
    .conf-low      { background: transparent;           color: var(--text-muted);     border: 1px solid var(--border-subtle); font-style: italic; }

    /* ── Banners ── */
    .banner {
      border-radius: 8px;
      padding: 14px 18px;
      margin-bottom: 16px;
      border-left: 3px solid;
      font-size: 13px;
      line-height: 1.65;
    }

    .banner strong { display: block; margin-bottom: 3px; font-weight: 700; }
    .banner-insufficient { background: var(--score-yellow-bg); border-color: var(--score-yellow);  color: #e3c86d; }
    .banner-gate         { background: var(--score-red-bg);    border-color: var(--score-red);     color: #f9a09b; }
    .banner-tribal       { background: rgba(88,166,255,0.07); border-color: var(--accent-blue);   color: #a2c5f2; }
    .banner-pci-legacy   { background: rgba(240,136,62,0.10); border-color: var(--accent-orange); color: #f5b07a; }

    /* ── Executive snapshot ── */
    .exec-snapshot {
      font-size: 15px;
      line-height: 1.85;
      color: var(--text-primary);
      font-weight: 300;
    }

    /* ── Scorecard bars ── */
    .composite-line {
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 18px;
    }

    .bar-row {
      padding: 13px 0;
      border-bottom: 1px solid var(--border-subtle);
    }

    .bar-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }

    .bar-name  { font-size: 13px; font-weight: 600; color: var(--text-primary); }
    .bar-score { font-family: var(--font-mono); font-size: 15px; font-weight: 700; }

    .bar-track {
      background: rgba(255,255,255,0.06);
      height: 5px;
      border-radius: 3px;
      overflow: hidden;
      margin-bottom: 7px;
    }

    .bar-fill {
      height: 5px;
      border-radius: 3px;
      transition: width 0.55s cubic-bezier(0.4,0,0.2,1);
    }

    .fill-green    { background: var(--score-green); }
    .fill-yellow   { background: var(--score-yellow); }
    .fill-red      { background: var(--score-red); }
    .fill-excluded { background: var(--text-muted); opacity: 0.35; }

    /* DIFFERENCE 2 — Awaiting Data state for academic_need */
    .fill-awaiting  { background: var(--text-muted); opacity: 0.15; }
    .awaiting-label { font-size: 11px; font-style: italic; color: var(--text-muted) !important;
                      font-weight: 400 !important; font-family: var(--font-sans); }
    .awaiting-pill  { background: transparent !important; border-color: var(--border-subtle) !important;
                      color: var(--text-muted) !important; font-style: italic; }
    .awaiting-note  { font-size: 11px; color: var(--text-muted); font-style: italic; margin-left: 4px; }

    .txt-green  { color: var(--score-green); }
    .txt-yellow { color: var(--score-yellow); }
    .txt-red    { color: var(--score-red); }
    .txt-muted  { color: var(--text-muted); }

    .bar-weight { font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); }
    .bar-driver { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }

    .excluded-sep {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-muted);
      margin: 22px 0 8px;
      letter-spacing: 0.06em;
    }

    .nullweight-pill {
      display: inline-block;
      background: transparent;
      border: 1px solid var(--border-subtle);
      color: var(--text-muted);
      border-radius: 999px;
      padding: 1px 8px;
      font-family: var(--font-mono);
      font-size: 10px;
      margin-right: 8px;
    }

    /* ── Top drivers ── */
    .driver-item {
      border-left: 2px solid var(--accent-blue);
      padding-left: 14px;
      margin-bottom: 10px;
      font-size: 13px;
      color: var(--text-secondary);
    }

    .driver-item strong { color: var(--text-primary); }

    /* ── Override flags ── */
    .flag-card {
      border-radius: 8px;
      border-left: 3px solid;
      padding: 12px 16px;
      margin-bottom: 10px;
    }

    .flag-card .flag-head { font-size: 13px; font-weight: 700; margin-bottom: 3px; }
    .flag-card .flag-body { font-size: 12px; color: var(--text-secondary); }
    .flag-green   { background: var(--score-green-bg);  border-color: var(--score-green); }
    .flag-amber   { background: var(--score-yellow-bg); border-color: var(--score-yellow); }
    .flag-red     { background: var(--score-red-bg);    border-color: var(--score-red); }
    .flag-neutral { background: var(--bg-card);         border-color: var(--border-muted); }

    /* DIFFERENCE 1 — Greenfield notice (replaces school cards) */
    .greenfield-notice {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      padding: 20px 22px;
    }

    .greenfield-notice-icon {
      font-size: 22px;
      color: var(--text-muted);
      flex-shrink: 0;
      margin-top: 1px;
      line-height: 1;
    }

    .greenfield-notice-text {
      font-size: 13px;
      color: var(--text-muted);
      font-style: italic;
      line-height: 1.7;
    }

    /* ── Authorizers ── */
    .auth-item { font-size: 13px; padding-left: 14px; margin-bottom: 8px; color: var(--text-secondary); }
    .auth-item .dash { color: var(--text-muted); margin-right: 4px; }
    .auth-item strong { color: var(--text-primary); }

    /* ── Recommendations ── */
    .rec-item { font-size: 13px; margin-bottom: 10px; color: var(--text-secondary); }
    .rec-item strong { color: var(--text-primary); }

    ol { padding-left: 18px; }
    ol li { padding-left: 6px; }

    /* ── Needs verification ── */
    .nv-item {
      border-left: 2px solid var(--score-yellow);
      padding-left: 12px;
      font-size: 12px;
      margin-bottom: 8px;
      color: var(--text-secondary);
    }

    .nv-item strong { color: var(--text-primary); }

    /* ── Sources ── */
    .src-item { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-bottom: 5px; }
    .src-item .dash { margin-right: 4px; }

    .muted-note { color: var(--text-muted); font-style: italic; font-size: 13px; }

    /* ── Quick reads ── */
    .qr-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }

    .qr-card {
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      padding: 14px 16px;
    }

    .qr-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 6px;
    }

    .qr-body { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }

    /* ── Footer ── */
    .disclosure-footer {
      background: var(--bg-secondary);
      border-top: 1px solid var(--border-subtle);
      padding: 20px 40px;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.75;
    }

    /* ── Debug ── */
    .debug-section { margin-top: 3em; }

    .debug-section details > summary {
      cursor: pointer;
      color: var(--text-muted);
      font-size: 0.82em;
      font-family: var(--font-mono);
      user-select: none;
      list-style: none;
    }

    .debug-section details > summary::before { content: "▶ "; }
    .debug-section details[open] > summary::before { content: "▼ "; }
    .debug-section details[open] > summary { margin-bottom: 0.8em; }

    .debug-meta { font-family: var(--font-mono); font-size: 0.8em; color: var(--text-muted); margin: 0.4em 0; }

    .debug-section table {
      font-family: var(--font-mono);
      font-size: 0.8em;
      color: var(--text-secondary);
      margin: 0.6em 0;
      border-collapse: collapse;
      width: 100%;
    }

    .debug-section th,
    .debug-section td { border: 1px solid var(--border-subtle); padding: 0.35em 0.55em; text-align: left; }
    .debug-section th { background: var(--bg-elevated); color: var(--text-muted); font-weight: normal; }
    .debug-section td { color: var(--text-secondary); }

    .debug-section td:nth-child(3),
    .debug-section td:nth-child(4),
    .debug-section td:nth-child(5) { text-align: right; }

    .debug-warn {
      font-family: var(--font-mono);
      font-size: 0.78em;
      color: var(--accent-orange);
      margin: 0.6em 0;
      padding: 0;
      list-style: none;
    }

    .debug-warn li { margin-bottom: 0.25em; }
    .debug-empty { font-size: 0.8em; color: var(--text-muted); font-style: italic; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .page-shell    { flex-direction: column; }
      .sidebar {
        width: 100%;
        height: auto;
        position: static;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 16px;
        padding: 20px 20px 16px;
        align-items: flex-start;
        border-right: none;
        border-bottom: 1px solid var(--border-subtle);
      }
      .sb-nav        { display: none; }
      .main-content  { padding: 24px 20px 56px; }
      .qr-grid       { grid-template-columns: 1fr; }
    }

    /* ── Print ── */
    @media print {
      @page {
        size: Letter;
        margin: 1.8cm 1.5cm;
      }

      * {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        animation: none !important;
        transition: none !important;
      }

      html, body {
        background: #0d1117 !important;
        color: #e6edf3 !important;
        font-size: 11px !important;
        line-height: 1.4 !important;
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
      }

      .main-content, .container, [class*="wrapper"],
      [class*="content"] {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0.3cm 0 !important;
        float: none !important;
      }

      .sidebar, .sidebar nav, .sb-nav, .sb-nav-label,
      .debug-section, button, .btn, [class*="tooltip"],
      [class*="dropdown"], nav {
        display: none !important;
      }

      a[href]::after {
        content: "" !important;
      }

      h1, h2, h3 {
        font-size: 1.1em !important;
      }

      .section-header, [class*="section-title"] {
        font-size: 0.8em !important;
        letter-spacing: 0.12em !important;
      }

      [class*="muted"], [class*="secondary"],
      [style*="color: #6e7681"], [style*="color: #8b949e"] {
        color: #b0bac4 !important;
      }

      .bar-track, .bar-fill, [class*="bar"] {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }

      .bar-row, .flag-card, .nv-item, .qr-card,
      .banner, .rec-item, .card, .condition-item,
      #datasources, #datasources table,
      .recommendation, [class*="rec-item"] {
        break-inside: avoid !important;
        page-break-inside: avoid !important;
      }

      #recommendations, #verification {
        break-before: page !important;
        page-break-before: always !important;
      }

      #scorecard, #datasources, #drivers, #flags,
      #schools, #landscape, #authorizers, #sources {
        break-before: auto !important;
        page-break-before: auto !important;
      }

      .composite-score, [class*="score-display"],
      [class*="score-widget"] {
        font-size: 0.9em !important;
      }

      .section, [class*="section"] {
        padding: 0.4cm 0 !important;
        margin: 0.2cm 0 !important;
      }

      #datasources table {
        font-size: 0.82em !important;
        width: 100% !important;
      }

      #datasources td, #datasources th {
        padding: 3px 6px !important;
      }

      .qr-grid { grid-template-columns: 1fr !important; }

      .greenfield-notice, .emerging-badge {
        break-inside: avoid !important;
      }
    }
  </style>
</head>
<body>

{# ─── VERDICT HEADER ─── #}
{% set comp = brief.composite_score if brief.composite_score is not none else 0 %}
{% set comp_tone = 'green' if comp >= 7.0 else ('yellow' if comp >= 4.0 else 'red') %}

<div class="page-shell">

  {# ── SIDEBAR ── #}
  <aside class="sidebar">
    <div class="sb-wordmark">CLIP</div>

    <div>
      <div class="sb-community">{{ brief.community_name | e }}<span class="sb-state">{{ brief.state | e }}</span></div>
    </div>

    {# Greenfield-only: Emerging Market badge #}
    <div class="emerging-badge">&#9675; Emerging Market</div>

    {% if brief.executive_snapshot %}
    <div class="sb-tagline">{{ (brief.executive_snapshot.split('. ') | first) | truncate(120, True, '…') | e }}</div>
    {% endif %}

    <div class="sb-score-block">
      <div class="sb-score-label">Composite Score</div>
      <div>
        <span class="sb-score-num sb-score-{{ comp_tone }}">{{ comp }}</span><span class="sb-score-max">/10</span>
      </div>
      <div class="sb-tier">{{ brief.scorecard_summary.tier_display_label | e }}</div>
    </div>

    <div class="sb-badges">
      {% if brief.classification %}<span class="pill pill-{{ comp_tone }}">{{ brief.classification | e }}</span>{% endif %}
      {% set co = (brief.confidence_overall or '') | upper %}
      {% if co == 'HIGH' %}<span class="conf conf-high">Confidence: High</span>
      {% elif co == 'MODERATE' %}<span class="conf conf-moderate">Confidence: Moderate</span>
      {% elif co == 'LOW' %}<span class="conf conf-low">Confidence: Low</span>{% endif %}
    </div>

    <div class="sb-through">Data through:<br>{{ brief.data_through | e }}</div>

    <nav>
      <div class="sb-nav-label">Sections</div>
      <ul class="sb-nav">
        <li><a href="#snapshot">Executive Snapshot</a></li>
        <li><a href="#scorecard">Scorecard</a></li>
        <li><a href="#drivers">Top Drivers</a></li>
        <li><a href="#flags">Override Flags</a></li>
        <li><a href="#schools">Charter Landscape</a></li>
        <li><a href="#authorizers">Authorizers</a></li>
        <li><a href="#recommendations">Recommendations</a></li>
        <li><a href="#quickreads">Quick Reads</a></li>
        <li><a href="#verification">Needs Verification</a></li>
        <li><a href="#sources">Sources</a></li>
      </ul>
    </nav>
  </aside>

  {# ── MAIN CONTENT ── #}
  <main class="main-content">

    {# ─── STATUTORY BARRIER BANNER ─── #}
    {% set _sb = brief.statutory_barrier %}
    {% set _prohib = (_sb and _sb.severity == 'prohibition' and _sb.applies == true) %}
    {% if _sb %}
    <div style="border:2px solid {{ '#b00020' if _prohib else '#b76e00' }}; background:{{ '#fdecec' if _prohib else '#fff6e5' }}; border-radius:8px; padding:16px 18px; margin:0 0 20px 0;">
      <div style="font-weight:800; font-size:15px; letter-spacing:.03em; color:{{ '#b00020' if _prohib else '#7a4b00' }}; margin-bottom:8px;">
        {% if _prohib %}&#x26A0; STATUTORY PROHIBITION — CHARTER SCHOOLS CANNOT BE BUILT HERE{% else %}&#x26A0; STATUTORY BARRIER — LOCAL BOARD APPROVAL REQUIRED{% endif %}
      </div>
      <div style="font-size:13.5px; line-height:1.5; color:#222;">{{ _sb.banner_text | e }}</div>
      {% if _sb.statute %}<div style="font-size:12.5px; margin-top:8px; color:#333;"><strong>Statute:</strong> {{ _sb.statute | e }}</div>{% endif %}
      {% if not _sb.evaluable %}<div style="font-size:12.5px; margin-top:6px; color:#7a4b00;"><em>District accountability rating not verified in-pipeline — this barrier may or may not apply to this community. Confirm the district's current rating.</em></div>{% endif %}
      <div style="font-size:12px; margin-top:8px; color:#555;"><em>This finding is based on verified statute text. Verify current law before strategic use.</em></div>
    </div>
    {% endif %}

    {# ─── BANNERS ─── #}
    {% if brief.data_coverage_tier == "INSUFFICIENT" %}
    <div class="banner banner-insufficient">
      <strong>&#x26A0; Insufficient data coverage</strong>
      Four or more scoring dimensions defaulted to midpoint. Treat the ranking and
      recommendations below as research directions, not confident calls.
    </div>
    {% endif %}

    {% if brief.recommendation_confidence_gate and brief.recommendation_confidence_gate.gated %}
    <div class="banner banner-gate">
      <strong>&#x1F6AB; Recommendation confidence: gated</strong>
      {{ brief.recommendation_confidence_gate.reason | e }}
    </div>
    {% endif %}

    {% if brief.tribal_jurisdiction_flag %}
    <div class="banner banner-tribal">
      <strong>&#x2139; Tribal jurisdiction: {{ (brief.tribal_jurisdiction_flag.status or '') | replace("_", " ") | e }}</strong>
      {{ brief.tribal_jurisdiction_flag.note | e }}
      {% if brief.tribal_jurisdiction_flag.resolution_path %}<br><em>Resolution:</em> {{ brief.tribal_jurisdiction_flag.resolution_path | e }}{% endif %}
    </div>
    {% endif %}

    {% if pci_promoted %}
    <div class="banner banner-pci-legacy">
      <strong>&#x26A0; Political climate score was recovered from a legacy cache entry.</strong>
      Confidence is reduced — re-run S3 to generate a fresh signal.
    </div>
    {% endif %}

    {# ─── 3. EXECUTIVE SNAPSHOT ─── #}
    <div class="section" id="snapshot">
      <p class="section-label">Executive Snapshot</p>
      <p class="exec-snapshot">{{ brief.executive_snapshot | e }}</p>
    </div>

    {# ─── DATA SOURCES & CONFIDENCE ─── #}
    {% if brief.data_sources %}
    <div class="section" id="datasources">
      <p class="section-label">Data Sources &amp; Confidence</p>
      <table style="width:100%; border-collapse:collapse; font-size:12.5px;">
        <thead>
          <tr style="text-align:left; color:var(--text-secondary); border-bottom:1px solid var(--border-muted);">
            <th style="padding:6px 8px;">Source</th><th style="padding:6px 8px;">Powers</th>
            <th style="padding:6px 8px;">Vintage</th><th style="padding:6px 8px;">Status</th>
          </tr>
        </thead>
        <tbody>
          {% for d in brief.data_sources %}
          {% set _c = 'var(--accent-green)' if d.status_icon == '✓' else ('var(--accent-yellow)' if d.status_icon == '⚠' else 'var(--accent-red)') %}
          <tr style="border-bottom:1px solid var(--border-subtle);">
            <td style="padding:6px 8px; color:var(--text-primary);">{{ d.source | e }}</td>
            <td style="padding:6px 8px; color:var(--text-secondary);">{{ d.powers | e }}</td>
            <td style="padding:6px 8px; color:var(--text-secondary);">{{ d.vintage | e }}</td>
            <td style="padding:6px 8px; color:{{ _c }}; white-space:nowrap;">{{ d.status_icon }} {{ d.status | e }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {# ─── 4. SCORECARD (bars) ─── #}
    {# Suppressed under a statutory prohibition — a prohibited market needs no score breakdown. #}
    {% set sc = brief.scorecard_summary %}
    {% if not _prohib %}
    <div class="section" id="scorecard">
      <p class="section-label">Scorecard</p>
      <p class="composite-line">Composite: {{ sc.composite_score }}/10 — {{ sc.tier_display_label | e }}</p>

      {% for row in sc.dimension_table if not row.used_default %}
      {% set tone = 'green' if row.score >= 7.0 else ('yellow' if row.score >= 4.0 else 'red') %}
      <div class="bar-row">
        <div class="bar-head">
          <span class="bar-name">{{ row.display_name | e }}</span>
          <span class="bar-score txt-{{ tone }}">{{ row.score }}</span>
        </div>
        <div class="bar-track">
          <div class="bar-fill fill-{{ tone }}" style="width: {{ '%.0f' | format(row.score / 10 * 100) }}%;"></div>
        </div>
        <div class="bar-weight">{{ (row.weight * 100) | int }}% weight</div>
        {% if row.driver %}<div class="bar-driver">{{ row.driver | e }}</div>{% endif %}
      </div>
      {% endfor %}

      {% set excluded = sc.dimension_table | selectattr("used_default") | list %}
      {% if excluded %}
      <div class="excluded-sep">─── Excluded from composite ───</div>
      {% for row in excluded %}
      {# DIFFERENCE 2: academic_need gets "Awaiting Data" state — no proficiency data for this state #}
      {% if row.dimension == 'academic_need' %}
      <div class="bar-row">
        <div class="bar-head">
          <span class="bar-name txt-muted">{{ row.display_name | e }}</span>
          <span class="bar-score awaiting-label">Awaiting Data</span>
        </div>
        <div class="bar-track">
          <div class="bar-fill fill-awaiting" style="width: 50%;"></div>
        </div>
        <div class="bar-driver">
          <span class="nullweight-pill awaiting-pill">no data</span><span class="awaiting-note">No proficiency data available for this state</span>
        </div>
      </div>
      {% else %}
      <div class="bar-row">
        <div class="bar-head">
          <span class="bar-name txt-muted">{{ row.display_name | e }}</span>
          <span class="bar-score txt-muted">{{ row.score }}</span>
        </div>
        <div class="bar-track">
          <div class="bar-fill fill-excluded" style="width: {{ '%.0f' | format(row.score / 10 * 100) }}%;"></div>
        </div>
        <div class="bar-driver">
          <span class="nullweight-pill">0% weight — not scored</span>{% if row.driver %}{{ row.driver | e }}{% endif %}
        </div>
      </div>
      {% endif %}
      {% endfor %}
      {% endif %}

      {% if sc.excluded_dimensions %}
      <p class="bar-weight" style="margin-top: 12px;">
        Excluded dimensions default to 5.0 and are removed from the composite; their
        weight is redistributed proportionally across scored dimensions.
        Excluded: {{ sc.excluded_dimensions | join(", ") | e }}.
        Displayed weights are rounded to whole percentages; exact scored weights sum to 100%.
      </p>
      {% set _both_demand_excluded = ('charter_saturation' in sc.excluded_dimensions) and ('competitive_opportunity' in sc.excluded_dimensions) %}
      {% if _both_demand_excluded %}
      <p class="bar-weight" style="margin-top: 8px;">
        Both demand dimensions (Charter Saturation, Competitive Opportunity) are excluded,
        so the composite measures operational viability — not charter demand.
      </p>
      {% endif %}
      {% endif %}
    </div>
    {% endif %}{# /not _prohib — scorecard #}

    {# ─── 5. TOP DRIVERS ─── #}
    {% if sc.top_drivers %}
    <div class="section" id="drivers">
      <p class="section-label">Top Drivers</p>
      {% for d in sc.top_drivers %}
      <div class="driver-item"><strong>{{ d.dimension | e }}</strong> ({{ d.score }}) — {{ d.driver | e }}</div>
      {% endfor %}
    </div>
    {% endif %}

    {# ─── 6. OVERRIDE FLAGS ─── #}
    <div class="section" id="flags">
      <p class="section-label">Override Flags</p>
      {% if sc.override_flags %}
      {% for flag in sc.override_flags %}
      {% set ftxt = ((flag.tier_effect or '') ~ ' ' ~ (flag.flag or '')) | lower %}
      {% if 'positive' in ftxt or 'friendly' in ftxt or 'boost' in ftxt %}
        {% set ftone = 'green' %}{% set ficon = '&#x2705;' %}
      {% elif 'hard' in ftxt or 'negative' in ftxt or 'penalty' in ftxt %}
        {% set ftone = 'red' %}{% set ficon = '&#x26A0;' %}
      {% elif 'cap' in ftxt %}
        {% set ftone = 'amber' %}{% set ficon = '&#x26A0;' %}
      {% else %}
        {% set ftone = 'neutral' %}{% set ficon = '&#x2139;' %}
      {% endif %}
      <div class="flag-card flag-{{ ftone }}">
        <div class="flag-head">{{ ficon }} {{ flag.flag | e }}</div>
        <div class="flag-body">{{ flag.triggered_by | e }}{% if flag.tier_effect %} <em>({{ flag.tier_effect | e }})</em>{% endif %}</div>
      </div>
      {% endfor %}
      {% else %}
      <p class="muted-note">No override flags triggered.</p>
      {% endif %}
    </div>

    {# ─── 7. CHARTER LANDSCAPE — DIFFERENCE 1 ─── #}
    {# Greenfield: no established charter landscape. School cards replaced with notice. #}
    <div class="section" id="schools">
      <p class="section-label">Charter Landscape</p>
      <div class="greenfield-notice">
        <div class="greenfield-notice-icon">&#9675;</div>
        <div class="greenfield-notice-text">
          No established charter landscape identified. School-level metrics will appear
          here once charter schools operate in this community.
        </div>
      </div>
    </div>

    {# ─── 8. LOCAL AUTHORIZERS ─── #}
    <div class="section" id="authorizers">
      <p class="section-label">Local Authorizers</p>
      {% if brief.local_authorizers %}
      {% for a in brief.local_authorizers %}
      <div class="auth-item">
        <span class="dash">—</span> <strong>{{ a.authorizer_name | e }}</strong>{% if a.type %} ({{ a.type | e }}){% endif %}{% if a.reputation_note %} — {{ a.reputation_note | e }}{% endif %}
      </div>
      {% endfor %}
      {% else %}
      <p class="muted-note">No local authorizer data available.</p>
      {% endif %}
    </div>

    {# ─── 9. RECOMMENDATIONS ─── #}
    {% if not _prohib %}
    <div class="section" id="recommendations">
      <p class="section-label">Recommendations</p>
      {% if brief.recommendation_confidence_gate and brief.recommendation_confidence_gate.gated %}
      <div class="banner banner-gate">
        <strong>&#x26A0; Recommendations provisional — pending verification</strong>
        Confidence gate active — {{ brief.recommendation_confidence_gate.reason | e }}
      </div>
      {% endif %}
      {% if brief.recommendations %}
      <ol>
        {% for rec in brief.recommendations %}
        <li class="rec-item">
          <strong>{{ rec.action | e }}</strong> — {{ rec.rationale | e }}<br>
          <span class="txt-muted" style="font-size:12px;"><em>Evidence:</em> {{ rec.evidence_summary | e }} · <em>Risk:</em> {{ rec.primary_risk | e }} · <em>Confidence:</em> {{ rec.confidence | e }}</span>
        </li>
        {% endfor %}
      </ol>
      {% endif %}
    </div>
    {% endif %}{# /not _prohib — recommendations #}

    {# ─── 10. QUICK READS ─── #}
    {% if brief.quick_reads %}
    <div class="section" id="quickreads">
      <p class="section-label">Quick Reads</p>
      <div class="qr-grid">
        <div class="qr-card">
          <div class="qr-label">Facilities</div>
          <div class="qr-body">{{ brief.quick_reads.facilities | e }}</div>
        </div>
        <div class="qr-card">
          <div class="qr-label">Political</div>
          <div class="qr-body">{{ brief.quick_reads.political | e }}</div>
        </div>
        <div class="qr-card">
          <div class="qr-label">Authorizer</div>
          <div class="qr-body">{{ brief.quick_reads.authorizer | e }}</div>
        </div>
      </div>
    </div>
    {% endif %}

    {# ─── 11. NEEDS VERIFICATION ─── #}
    {% if brief.needs_verification %}
    <div class="section" id="verification">
      <p class="section-label">Needs Verification</p>
      {% for item in brief.needs_verification %}
      <div class="nv-item">
        <strong>{{ item.claim | e }}</strong> — {{ item.reason | e }}
        {% if item.impact_if_wrong %}<em>(Impact: {{ item.impact_if_wrong | e }})</em>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {# ─── 12. SOURCES ─── #}
    {% if brief.sources %}
    <div class="section" id="sources">
      <p class="section-label">Sources</p>
      {% for s in brief.sources %}
      <div class="src-item">
        <span class="dash">—</span> [{{ s.ref_num }}] {{ s.title | e }} · {{ s.source_class | e }}{% if s.url %} · {{ s.url | e }}{% endif %}{% if s.date %} · {{ s.date | e }}{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {# ─── DEBUG (screen only) ─── #}
    {% if debug is defined %}
    <div class="debug-section">
      <details>
        <summary>Pipeline Debug Log</summary>
        <p class="debug-meta">Run ID: {{ debug.run_id }}</p>
        <p class="debug-meta">Timestamp: {{ debug.timestamp }}</p>
        <p class="debug-meta">Depth: {{ debug.depth }}</p>

        <p class="debug-meta"><strong>Token Usage</strong></p>
        {% if debug.token_rows %}
        <table>
          <thead>
            <tr>
              <th>Stage</th>
              <th>Model</th>
              <th>Tokens In</th>
              <th>Tokens Out</th>
              <th>Est. Cost</th>
            </tr>
          </thead>
          <tbody>
            {% for row in debug.token_rows %}
            <tr>
              <td>{{ row.stage }}</td>
              <td>{{ row.model }}</td>
              <td>{{ "{:,}".format(row.tokens_input) }}</td>
              <td>{{ "{:,}".format(row.tokens_output) }}</td>
              <td>${{ "%.4f"|format(row.cost) }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        {% else %}
        <p class="debug-empty">No API calls this run.</p>
        {% endif %}

        {% if debug.warn_lines %}
        <p class="debug-meta"><strong>Warnings &amp; Errors</strong></p>
        <ul class="debug-warn">
          {% for line in debug.warn_lines %}
          <li>{{ line | e }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </details>
    </div>
    {% endif %}

  </main>

</div>

{# ─── FOOTER ─── #}
<div class="disclosure-footer">
  This brief is AI-generated and requires human review before any capital commitment
  or site-selection decision. Data accuracy is not guaranteed.<br>
  Generated by CLIP · {{ brief.generated_at | e if brief.generated_at else '' }} · Emerging Market — no established charter landscape
</div>

<script>
  document.querySelectorAll('.sb-nav a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  var sections = document.querySelectorAll('.section[id]');
  var navLinks = document.querySelectorAll('.sb-nav a');
  if (sections.length && navLinks.length) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          navLinks.forEach(function(link) {
            var active = link.getAttribute('href') === '#' + entry.target.id;
            link.style.fontWeight = active ? '600' : '';
            link.style.color      = active ? 'var(--text-primary)' : '';
          });
        }
      });
    }, { threshold: 0.3 });
    sections.forEach(function(s) { observer.observe(s); });
  }
</script>

</body>
</html>
