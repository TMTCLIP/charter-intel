<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ brief.community_name | e }}, {{ brief.state | e }} — Ineligible Market</title>
  <!-- No external font CDN — offline-safe system stacks throughout -->
  <style>
    :root {
      --bg-primary:    #0d1117;
      --bg-secondary:  #161b22;
      --bg-card:       #1c2128;
      --bg-elevated:   #22272e;
      --border-subtle: rgba(255,255,255,0.08);
      --border-muted:  rgba(255,255,255,0.15);
      --text-primary:  #e6edf3;
      --text-secondary:#8b949e;
      --text-muted:    #6e7681;
      --accent-green:  #3fb950;
      --accent-yellow: #d29922;
      --accent-red:    #f85149;
      --accent-blue:   #58a6ff;
      --accent-orange: #f0883e;
      --score-green:      #3fb950;
      --score-green-bg:   rgba(63,185,80,0.12);
      --score-yellow:     #d29922;
      --score-yellow-bg:  rgba(210,153,34,0.12);
      --score-red:        #f85149;
      --score-red-bg:     rgba(248,81,73,0.12);
      --sidebar-width: 260px;
      --font-sans:  -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      --font-mono:  ui-monospace, 'Cascadia Code', 'SF Mono', 'Fira Code', Menlo, Consolas, 'Courier New', monospace;
      --font-serif: Georgia, 'Times New Roman', serif;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes scaleIn {
      from { transform: scale(0.92); opacity: 0; }
      to   { transform: scale(1);    opacity: 1; }
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 1.6;
      color: var(--text-primary);
      background: var(--bg-primary);
    }

    /* ── Page layout ── */
    .page-shell {
      display: flex;
      max-width: 1140px;
      margin: 0 auto;
      min-height: 100vh;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: var(--sidebar-width);
      flex-shrink: 0;
      background: var(--bg-secondary);
      border-right: 1px solid var(--border-subtle);
      padding: 28px 20px 40px;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    .sb-wordmark {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .sb-community {
      font-family: var(--font-serif);
      font-size: 22px;
      line-height: 1.2;
      color: var(--text-primary);
    }

    .sb-state {
      display: block;
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 300;
      color: var(--text-secondary);
      margin-top: 4px;
    }

    /* INELIGIBLE badge */
    .ineligible-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: 20px;
      background: rgba(248,81,73,0.12);
      border: 1px solid rgba(248,81,73,0.3);
      color: var(--accent-red);
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      width: fit-content;
    }

    .sb-score-block {
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 10px;
      padding: 16px;
      animation: scaleIn 0.4s ease both;
    }

    .sb-score-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .sb-score-num {
      font-family: var(--font-serif);
      font-size: 52px;
      line-height: 1;
      letter-spacing: -1px;
    }

    .sb-score-max {
      font-size: 18px;
      font-family: var(--font-sans);
      font-weight: 300;
      color: var(--text-muted);
    }

    .sb-tier {
      font-size: 11px;
      color: var(--text-secondary);
      margin-top: 8px;
    }

    .sb-score-red    { color: var(--score-red); }
    .sb-score-yellow { color: var(--score-yellow); }
    .sb-score-green  { color: var(--score-green); }

    .sb-through {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .sb-nav-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 0 8px;
      margin-bottom: 4px;
    }

    .sb-nav {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .sb-nav a {
      display: block;
      padding: 5px 8px;
      border-radius: 5px;
      color: var(--text-secondary);
      font-size: 12px;
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
    }

    .sb-nav a:hover {
      background: var(--bg-elevated);
      color: var(--text-primary);
    }

    /* ── Main content ── */
    .main-content {
      flex: 1;
      min-width: 0;
      padding: 32px 40px 72px;
    }

    .section {
      margin-top: 36px;
      animation: fadeIn 0.35s ease both;
    }

    .section-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 14px;
      padding-bottom: 7px;
      border-bottom: 1px solid var(--border-subtle);
    }

    /* ── Banners ── */
    .banner {
      border-radius: 8px;
      padding: 14px 18px;
      margin-bottom: 16px;
      border-left: 3px solid;
      font-size: 13px;
      line-height: 1.65;
    }

    .banner strong { display: block; margin-bottom: 3px; font-weight: 700; }
    .banner-insufficient { background: var(--score-yellow-bg); border-color: var(--score-yellow); color: #e3c86d; }
    .banner-ineligible   { background: var(--score-red-bg);    border-color: var(--score-red);    color: #f9a09b; }

    /* Verdict banner — prominent ineligibility reason */
    .verdict-banner {
      background: rgba(248,81,73,0.06);
      border: 1px solid rgba(248,81,73,0.3);
      border-left: 4px solid var(--accent-red);
      border-radius: 8px;
      padding: 18px 22px;
      margin-bottom: 28px;
    }

    .verdict-banner-title {
      font-family: var(--font-mono);
      font-weight: 700;
      color: var(--accent-red);
      font-size: 14px;
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }

    .verdict-banner-body {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* ── Executive snapshot ── */
    .exec-snapshot {
      font-size: 15px;
      line-height: 1.85;
      color: var(--text-primary);
      font-weight: 300;
    }

    /* ── Scorecard bars ── */
    .composite-line {
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 18px;
    }

    .bar-row {
      padding: 13px 0;
      border-bottom: 1px solid var(--border-subtle);
    }

    .bar-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }

    .bar-name  { font-size: 13px; font-weight: 600; color: var(--text-primary); }
    .bar-score { font-family: var(--font-mono); font-size: 15px; font-weight: 700; }

    .bar-track {
      background: rgba(255,255,255,0.06);
      height: 5px;
      border-radius: 3px;
      overflow: hidden;
      margin-bottom: 7px;
    }

    .bar-fill {
      height: 5px;
      border-radius: 3px;
      transition: width 0.55s cubic-bezier(0.4,0,0.2,1);
    }

    .fill-green    { background: var(--score-green); }
    .fill-yellow   { background: var(--score-yellow); }
    .fill-red      { background: var(--score-red); }
    .fill-excluded { background: var(--text-muted); opacity: 0.35; }
    .fill-awaiting { background: var(--text-muted); opacity: 0.15; }

    .awaiting-label { font-size: 11px; font-style: italic; color: var(--text-muted) !important;
                      font-weight: 400 !important; font-family: var(--font-sans); }
    .awaiting-pill  { background: transparent !important; border-color: var(--border-subtle) !important;
                      color: var(--text-muted) !important; font-style: italic; }
    .awaiting-note  { font-size: 11px; color: var(--text-muted); font-style: italic; margin-left: 4px; }

    .txt-green  { color: var(--score-green); }
    .txt-yellow { color: var(--score-yellow); }
    .txt-red    { color: var(--score-red); }
    .txt-muted  { color: var(--text-muted); }

    .bar-weight { font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); }
    .bar-driver { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }

    .excluded-sep {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-muted);
      margin: 22px 0 8px;
      letter-spacing: 0.06em;
    }

    .nullweight-pill {
      display: inline-block;
      background: transparent;
      border: 1px solid var(--border-subtle);
      color: var(--text-muted);
      border-radius: 999px;
      padding: 1px 8px;
      font-family: var(--font-mono);
      font-size: 10px;
      margin-right: 8px;
    }

    /* ── Top drivers ── */
    .driver-item {
      border-left: 2px solid var(--accent-red);
      padding-left: 14px;
      margin-bottom: 10px;
      font-size: 13px;
      color: var(--text-secondary);
    }

    .driver-item strong { color: var(--text-primary); }

    /* ── Override flags ── */
    .flag-card {
      border-radius: 8px;
      border-left: 3px solid;
      padding: 12px 16px;
      margin-bottom: 10px;
    }

    .flag-card .flag-head { font-size: 13px; font-weight: 700; margin-bottom: 3px; }
    .flag-card .flag-body { font-size: 12px; color: var(--text-secondary); }
    .flag-green   { background: var(--score-green-bg);  border-color: var(--score-green); }
    .flag-amber   { background: var(--score-yellow-bg); border-color: var(--score-yellow); }
    .flag-red     { background: var(--score-red-bg);    border-color: var(--score-red); }
    .flag-neutral { background: var(--bg-card);         border-color: var(--border-muted); }

    /* ── Conditions for re-evaluation (ineligible-specific) ── */
    .condition-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      font-size: 13px;
      color: var(--text-secondary);
      padding: 10px 14px;
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 6px;
      margin-bottom: 8px;
    }

    .condition-bullet {
      color: var(--accent-yellow);
      font-weight: 700;
      flex-shrink: 0;
      font-family: var(--font-mono);
    }

    /* ── Ineligible market notice (replaces school cards) ── */
    .ineligible-notice {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      padding: 20px 22px;
    }

    .ineligible-notice-icon {
      font-size: 22px;
      color: var(--accent-red);
      flex-shrink: 0;
      margin-top: 1px;
      line-height: 1;
      opacity: 0.7;
    }

    .ineligible-notice-text {
      font-size: 13px;
      color: var(--text-muted);
      font-style: italic;
      line-height: 1.7;
    }

    /* ── Recommendations suppressed (ineligible-specific) ── */
    .rec-suppressed {
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      padding: 16px 20px;
      font-size: 13px;
      color: var(--text-muted);
      font-style: italic;
    }

    /* ── Authorizers ── */
    .auth-item { font-size: 13px; padding-left: 14px; margin-bottom: 8px; color: var(--text-secondary); }
    .auth-item .dash { color: var(--text-muted); margin-right: 4px; }
    .auth-item strong { color: var(--text-primary); }

    /* ── Needs verification ── */
    .nv-item {
      border-left: 2px solid var(--score-yellow);
      padding-left: 12px;
      font-size: 12px;
      margin-bottom: 8px;
      color: var(--text-secondary);
    }

    .nv-item strong { color: var(--text-primary); }

    /* ── Sources ── */
    .src-item { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-bottom: 5px; }
    .src-item .dash { margin-right: 4px; }

    .muted-note { color: var(--text-muted); font-style: italic; font-size: 13px; }

    /* ── Debug ── */
    .debug-section { margin-top: 3em; }

    .debug-section details > summary {
      cursor: pointer;
      color: var(--text-muted);
      font-size: 0.82em;
      font-family: var(--font-mono);
      user-select: none;
      list-style: none;
    }

    .debug-section details > summary::before { content: "▶ "; }
    .debug-section details[open] > summary::before { content: "▼ "; }
    .debug-section details[open] > summary { margin-bottom: 0.8em; }

    .debug-meta { font-family: var(--font-mono); font-size: 0.8em; color: var(--text-muted); margin: 0.4em 0; }

    .debug-section table {
      font-family: var(--font-mono);
      font-size: 0.8em;
      color: var(--text-secondary);
      margin: 0.6em 0;
      border-collapse: collapse;
      width: 100%;
    }

    .debug-section th,
    .debug-section td { border: 1px solid var(--border-subtle); padding: 0.35em 0.55em; text-align: left; }
    .debug-section th { background: var(--bg-elevated); color: var(--text-muted); font-weight: normal; }
    .debug-section td { color: var(--text-secondary); }

    .debug-section td:nth-child(3),
    .debug-section td:nth-child(4),
    .debug-section td:nth-child(5) { text-align: right; }

    .debug-warn {
      font-family: var(--font-mono);
      font-size: 0.78em;
      color: var(--accent-orange);
      margin: 0.6em 0;
      padding: 0;
      list-style: none;
    }

    .debug-warn li { margin-bottom: 0.25em; }
    .debug-empty { font-size: 0.8em; color: var(--text-muted); font-style: italic; }

    /* ── Footer ── */
    .disclosure-footer {
      background: var(--bg-secondary);
      border-top: 1px solid var(--border-subtle);
      padding: 20px 40px;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.75;
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .page-shell    { flex-direction: column; }
      .sidebar {
        width: 100%;
        height: auto;
        position: static;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 16px;
        padding: 20px 20px 16px;
        align-items: flex-start;
        border-right: none;
        border-bottom: 1px solid var(--border-subtle);
      }
      .sb-nav        { display: none; }
      .main-content  { padding: 24px 20px 56px; }
    }

    /* ── Print ── */
    @media print {
      @page { margin: 1.5cm; }

      /* Preserve dark Van Gogh theme in PDF — force color rendering */
      html {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      /* Remove sticky sidebar; reflow to full-width column for PDF */
      .page-shell {
        flex-direction: column !important;
        max-width: 100% !important;
        width: 100% !important;
      }

      .sidebar {
        position: static !important;
        width: 100% !important;
        height: auto !important;
        overflow: visible !important;
        border-right: none !important;
        border-bottom: 1px solid var(--border-muted) !important;
        padding-bottom: 20px !important;
        break-after: avoid;
        page-break-after: avoid;
      }

      .main-content { padding: 16px 0 !important; }

      /* Kill animations/transitions for clean PDF rendering */
      * { animation: none !important; transition: none !important; }

      /* Hide screen-only interactive elements */
      .sidebar nav,
      .debug-section { display: none !important; }

      /* Suppress href URLs from printing after anchor text */
      a[href]::after { content: "" !important; }

      /* Bump --text-secondary (#8b949e) toward white for dark-bg readability */
      .sb-state, .sb-tagline, .sb-tier, .composite-line,
      .bar-driver, .driver-item, .flag-body,
      .auth-item, .rec-item, .nv-item, .qr-body,
      .verdict-banner-body, .condition-item { color: #b0bec9 !important; }

      /* Bump --text-muted (#6e7681) — too dark on dark background in print */
      .sb-wordmark, .sb-through, .sb-score-label,
      .bar-weight, .src-item, .qr-label,
      .excluded-sep, .txt-muted, .awaiting-label, .awaiting-note,
      .section-label, .muted-note, .nullweight-pill,
      .ineligible-notice-text, .rec-suppressed { color: #8b949e !important; }

      /* Quick reads: single column for print layout */
      .qr-grid { grid-template-columns: 1fr !important; }

      /* Never split these blocks across a page boundary */
      .bar-row,
      .flag-card,
      .driver-item,
      .nv-item,
      .banner,
      .sb-score-block,
      .condition-item,
      .ineligible-notice,
      .rec-suppressed {
        break-inside: avoid !important;
        page-break-inside: avoid !important;
      }

      /* Keep each data-sources table row intact */
      #datasources tr {
        break-inside: avoid !important;
        page-break-inside: avoid !important;
      }

      /* Keep data-sources table on one page; start fresh if it won't fit after snapshot */
      #datasources, #datasources table {
        break-inside: avoid;
        page-break-inside: avoid;
        break-before: page;
        page-break-before: always;
      }

      /* Verdict banner stays with scorecard on page 1 */
      .verdict-banner {
        break-inside: avoid !important;
        page-break-inside: avoid !important;
        break-after: avoid;
        page-break-after: avoid;
      }

      /* Snapshot section flows into scorecard without a break */
      #snapshot {
        break-after: avoid;
        page-break-after: avoid;
      }

      /* Allow natural page breaks between major sections */
      .section { break-before: auto; page-break-before: auto; }

      /* Major sections always start at the top of a new page */
      #scorecard,
      #recommendations,
      #verification {
        break-before: page !important;
        page-break-before: always !important;
      }
    }
  </style>
</head>
<body>

{# ─── SCORE TONE ─── #}
{% set sc = brief.scorecard_summary %}
{% set comp = brief.composite_score if brief.composite_score is not none else (sc.composite_score if sc else 0) %}
{% set comp_tone = 'green' if comp >= 7.0 else ('yellow' if comp >= 4.0 else 'red') %}

<div class="page-shell">

  {# ── SIDEBAR ── #}
  <aside class="sidebar">
    <div class="sb-wordmark">CLIP</div>

    <div>
      <div class="sb-community">{{ brief.community_name | e }}<span class="sb-state">{{ brief.state | e }}</span></div>
    </div>

    <div class="ineligible-badge">&#x26A0; Ineligible</div>

    <div class="sb-score-block">
      <div class="sb-score-label">Composite Score</div>
      <div>
        <span class="sb-score-num sb-score-{{ comp_tone }}">{{ comp }}</span><span class="sb-score-max">/10</span>
      </div>
      {% if sc %}<div class="sb-tier">{{ sc.tier_display_label | e }}</div>{% endif %}
    </div>

    <div class="sb-through">Data through:<br>{{ brief.data_through | e }}</div>

    <nav>
      <div class="sb-nav-label">Sections</div>
      <ul class="sb-nav">
        <li><a href="#snapshot">Market Context</a></li>
        <li><a href="#scorecard">Scorecard</a></li>
        <li><a href="#drivers">Top Drivers</a></li>
        <li><a href="#flags">Override Flags</a></li>
        <li><a href="#reevaluation">Re-evaluation</a></li>
        <li><a href="#landscape">Charter Landscape</a></li>
        <li><a href="#authorizers">Authorizers</a></li>
        <li><a href="#recommendations">Recommendations</a></li>
        <li><a href="#verification">Needs Verification</a></li>
        <li><a href="#sources">Sources</a></li>
      </ul>
    </nav>
  </aside>

  {# ── MAIN CONTENT ── #}
  <main class="main-content">

    {# ─── STATUTORY BARRIER BANNER (above the verdict header) ─── #}
    {% set _sb = brief.statutory_barrier %}
    {% set _prohib = (_sb and _sb.severity == 'prohibition' and _sb.applies == true) %}
    {% if _sb %}
    <div style="border:2px solid {{ '#b00020' if _prohib else '#b76e00' }}; background:{{ '#fdecec' if _prohib else '#fff6e5' }}; border-radius:8px; padding:16px 18px; margin:0 0 20px 0;">
      <div style="font-weight:800; font-size:15px; letter-spacing:.03em; color:{{ '#b00020' if _prohib else '#7a4b00' }}; margin-bottom:8px;">
        {% if _prohib %}&#x26A0; STATUTORY PROHIBITION — CHARTER SCHOOLS CANNOT BE BUILT HERE{% else %}&#x26A0; STATUTORY BARRIER — LOCAL BOARD APPROVAL REQUIRED{% endif %}
      </div>
      <div style="font-size:13.5px; line-height:1.5; color:#222;">{{ _sb.banner_text | e }}</div>
      {% if _sb.statute %}<div style="font-size:12.5px; margin-top:8px; color:#333;"><strong>Statute:</strong> {{ _sb.statute | e }}</div>{% endif %}
      {% if not _sb.evaluable %}<div style="font-size:12.5px; margin-top:6px; color:#7a4b00;"><em>District accountability rating not verified in-pipeline — this barrier may or may not apply to this community. Confirm the district's current rating.</em></div>{% endif %}
      <div style="font-size:12px; margin-top:8px; color:#555;"><em>This finding is based on verified statute text. Verify current law before strategic use.</em></div>
    </div>
    {% endif %}

    {# ─── VERDICT BANNER (ineligible-specific, always shown) ─── #}
    <div class="verdict-banner">
      <div class="verdict-banner-title">&#x26A0;&ensp;VERDICT: INELIGIBLE</div>
      <div class="verdict-banner-body">
        {% if sc %}
        Composite score: <strong>{{ comp }} / 10</strong>
        ({{ sc.tier_display_label | e }}) — below the minimum threshold for charter expansion.
        {% set low_dims = sc.dimension_table | selectattr('score', 'defined') | selectattr('used_default', 'equalto', false) | list if sc.dimension_table else [] %}
        {% set low_dims = low_dims | selectattr('score', 'lt', 4.0) | list %}
        {% if low_dims %}
        Dimensions below 4.0:
        <strong>{{ low_dims | map(attribute='display_name') | join(', ') | e }}</strong>.
        {% endif %}
        {% else %}
        This community did not pass the minimum scoring threshold for charter expansion.
        {% endif %}
        The analysis below identifies which dimensions drove the low score and the
        conditions under which re-evaluation would be warranted.
      </div>
    </div>

    {# ─── DATA COVERAGE BANNER ─── #}
    {% if brief.data_coverage_tier == "INSUFFICIENT" %}
    <div class="banner banner-insufficient">
      <strong>&#x26A0; Insufficient data coverage</strong>
      Four or more scoring dimensions defaulted to midpoint. The scorecard below rests
      largely on redistributed default values, not verified evidence.
    </div>
    {% endif %}

    {# ─── 1. EXECUTIVE SNAPSHOT ─── #}
    {% if brief.executive_snapshot %}
    <div class="section" id="snapshot">
      <p class="section-label">Market Context</p>
      <p class="exec-snapshot">{{ brief.executive_snapshot | e }}</p>
    </div>
    {% endif %}

    {# ─── DATA SOURCES & CONFIDENCE ─── #}
    {% if brief.data_sources %}
    <div class="section" id="datasources">
      <p class="section-label">Data Sources &amp; Confidence</p>
      <table style="width:100%; border-collapse:collapse; font-size:12.5px;">
        <thead>
          <tr style="text-align:left; color:var(--text-secondary); border-bottom:1px solid var(--border-muted);">
            <th style="padding:6px 8px;">Source</th><th style="padding:6px 8px;">Powers</th>
            <th style="padding:6px 8px;">Vintage</th><th style="padding:6px 8px;">Status</th>
          </tr>
        </thead>
        <tbody>
          {% for d in brief.data_sources %}
          {% set _c = 'var(--accent-green)' if d.status_icon == '✓' else ('var(--accent-yellow)' if d.status_icon == '⚠' else 'var(--accent-red)') %}
          <tr style="border-bottom:1px solid var(--border-subtle);">
            <td style="padding:6px 8px; color:var(--text-primary);">{{ d.source | e }}</td>
            <td style="padding:6px 8px; color:var(--text-secondary);">{{ d.powers | e }}</td>
            <td style="padding:6px 8px; color:var(--text-secondary);">{{ d.vintage | e }}</td>
            <td style="padding:6px 8px; color:{{ _c }}; white-space:nowrap;">{{ d.status_icon }} {{ d.status | e }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {# ─── 2. SCORECARD BARS ─── #}
    {# Suppressed under a statutory prohibition — a prohibited market needs no score breakdown. #}
    {% if sc and not _prohib %}
    <div class="section" id="scorecard">
      <p class="section-label">Scorecard — Ineligibility Drivers</p>
      <p class="composite-line">Composite: {{ comp }}/10 — {{ sc.tier_display_label | e }}</p>

      {% for row in sc.dimension_table if not row.used_default %}
      {% set tone = 'green' if row.score >= 7.0 else ('yellow' if row.score >= 4.0 else 'red') %}
      <div class="bar-row">
        <div class="bar-head">
          <span class="bar-name">{{ row.display_name | e }}</span>
          <span class="bar-score txt-{{ tone }}">{{ row.score }}</span>
        </div>
        <div class="bar-track">
          <div class="bar-fill fill-{{ tone }}" style="width: {{ '%.0f' | format(row.score / 10 * 100) }}%;"></div>
        </div>
        <div class="bar-weight">{{ (row.weight * 100) | int }}% weight</div>
        {% if row.driver %}<div class="bar-driver">{{ row.driver | e }}</div>{% endif %}
      </div>
      {% endfor %}

      {% set excluded = sc.dimension_table | selectattr("used_default") | list if sc.dimension_table else [] %}
      {% if excluded %}
      <div class="excluded-sep">─── Excluded from composite ───</div>
      {% for row in excluded %}
      {% if row.dimension == 'academic_need' %}
      <div class="bar-row">
        <div class="bar-head">
          <span class="bar-name txt-muted">{{ row.display_name | e }}</span>
          <span class="bar-score awaiting-label">Awaiting Data</span>
        </div>
        <div class="bar-track">
          <div class="bar-fill fill-awaiting" style="width: 50%;"></div>
        </div>
        <div class="bar-driver">
          <span class="nullweight-pill awaiting-pill">no data</span><span class="awaiting-note">No proficiency data available for this state</span>
        </div>
      </div>
      {% else %}
      <div class="bar-row">
        <div class="bar-head">
          <span class="bar-name txt-muted">{{ row.display_name | e }}</span>
          <span class="bar-score txt-muted">{{ row.score }}</span>
        </div>
        <div class="bar-track">
          <div class="bar-fill fill-excluded" style="width: {{ '%.0f' | format(row.score / 10 * 100) }}%;"></div>
        </div>
        <div class="bar-driver">
          <span class="nullweight-pill">0% weight — not scored</span>{% if row.driver %}{{ row.driver | e }}{% endif %}
        </div>
      </div>
      {% endif %}
      {% endfor %}
      {% endif %}

      {% if sc.excluded_dimensions %}
      <p class="bar-weight" style="margin-top: 12px;">
        Excluded dimensions default to 5.0 and are removed from the composite.
        Excluded: {{ sc.excluded_dimensions | join(", ") | e }}.
      </p>
      {% endif %}
    </div>
    {% endif %}

    {# ─── 3. TOP DRIVERS ─── #}
    {% if sc and sc.top_drivers %}
    <div class="section" id="drivers">
      <p class="section-label">Top Drivers of Ineligibility</p>
      {% for d in sc.top_drivers %}
      <div class="driver-item"><strong>{{ d.dimension | e }}</strong> ({{ d.score }}) — {{ d.driver | e }}</div>
      {% endfor %}
    </div>
    {% endif %}

    {# ─── 4. OVERRIDE FLAGS ─── #}
    <div class="section" id="flags">
      <p class="section-label">Override Flags</p>
      {% if sc and sc.override_flags %}
      {% for flag in sc.override_flags %}
      {% set ftxt = ((flag.tier_effect or '') ~ ' ' ~ (flag.flag or '')) | lower %}
      {% if 'positive' in ftxt or 'friendly' in ftxt or 'boost' in ftxt %}
        {% set ftone = 'green' %}{% set ficon = '&#x2705;' %}
      {% elif 'hard' in ftxt or 'negative' in ftxt or 'penalty' in ftxt %}
        {% set ftone = 'red' %}{% set ficon = '&#x26A0;' %}
      {% elif 'cap' in ftxt %}
        {% set ftone = 'amber' %}{% set ficon = '&#x26A0;' %}
      {% else %}
        {% set ftone = 'neutral' %}{% set ficon = '&#x2139;' %}
      {% endif %}
      <div class="flag-card flag-{{ ftone }}">
        <div class="flag-head">{{ ficon }} {{ flag.flag | e }}</div>
        <div class="flag-body">{{ flag.triggered_by | e }}{% if flag.tier_effect %} <em>({{ flag.tier_effect | e }})</em>{% endif %}</div>
      </div>
      {% endfor %}
      {% else %}
      <p class="muted-note">No override flags triggered.</p>
      {% endif %}
    </div>

    {# ─── 5. CONDITIONS FOR RE-EVALUATION (ineligible-specific) ─── #}
    {% if sc and sc.dimension_table %}
    {% set low_dims = [] %}
    {% for row in sc.dimension_table %}
      {% if row.score is defined and row.score is not none and row.score < 4.0 and not row.get('used_default', false) %}
        {% set _ = low_dims.append(row) %}
      {% endif %}
    {% endfor %}
    {% if low_dims %}
    <div class="section" id="reevaluation">
      <p class="section-label">Conditions for Re-evaluation</p>
      {% for row in low_dims %}
      <div class="condition-item">
        <span class="condition-bullet">&#8594;</span>
        <span>
          <strong>{{ row.display_name | e }}</strong>
          scored {{ row.score }} / 10.
          Meaningful improvement in this dimension would most directly lift the
          composite toward the eligible threshold.
        </span>
      </div>
      {% endfor %}
    </div>
    {% endif %}
    {% endif %}

    {# ─── 6. CHARTER LANDSCAPE — ineligible notice ─── #}
    <div class="section" id="landscape">
      <p class="section-label">Charter Landscape</p>
      <div class="ineligible-notice">
        <div class="ineligible-notice-icon">&#x26D4;</div>
        <div class="ineligible-notice-text">
          Market ineligible for charter development. School-level opportunity cards are
          suppressed — this community did not pass the scoring gate required for expansion
          analysis. School-level data will appear here if eligibility status changes.
        </div>
      </div>
    </div>

    {# ─── 7. LOCAL AUTHORIZERS ─── #}
    <div class="section" id="authorizers">
      <p class="section-label">Local Authorizers</p>
      {% if brief.local_authorizers %}
      {% for a in brief.local_authorizers %}
      <div class="auth-item">
        <span class="dash">—</span> <strong>{{ a.authorizer_name | e }}</strong>{% if a.type %} ({{ a.type | e }}){% endif %}{% if a.reputation_note %} — {{ a.reputation_note | e }}{% endif %}
      </div>
      {% endfor %}
      {% else %}
      <p class="muted-note">No local authorizer data available.</p>
      {% endif %}
    </div>

    {# ─── 8. RECOMMENDATIONS — suppressed for ineligible ─── #}
    <div class="section" id="recommendations">
      <p class="section-label">Recommendations</p>
      <div class="rec-suppressed">
        No recommendations generated. Expansion recommendations are gated for ineligible
        markets — this community did not pass the scoring threshold required to generate
        actionable guidance.
      </div>
    </div>

    {# ─── 9. NEEDS VERIFICATION ─── #}
    {% if brief.needs_verification %}
    <div class="section" id="verification">
      <p class="section-label">Needs Verification</p>
      {% for item in brief.needs_verification %}
      <div class="nv-item">
        <strong>{{ item.claim | e }}</strong>{% if item.reason %} — {{ item.reason | e }}{% endif %}
        {% if item.impact_if_wrong %}<em>(Impact: {{ item.impact_if_wrong | e }})</em>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {# ─── 10. SOURCES ─── #}
    {% if brief.sources %}
    <div class="section" id="sources">
      <p class="section-label">Sources</p>
      {% for s in brief.sources %}
      <div class="src-item">
        <span class="dash">—</span> [{{ s.ref_num }}] {{ s.title | e }} · {{ s.source_class | e }}{% if s.url %} · {{ s.url | e }}{% endif %}{% if s.date %} · {{ s.date | e }}{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {# ─── DEBUG (screen only) ─── #}
    {% if debug is defined %}
    <div class="debug-section">
      <details>
        <summary>Pipeline Debug Log</summary>
        <p class="debug-meta">Run ID: {{ debug.run_id }}</p>
        <p class="debug-meta">Timestamp: {{ debug.timestamp }}</p>
        <p class="debug-meta">Depth: {{ debug.depth }}</p>

        <p class="debug-meta"><strong>Token Usage</strong></p>
        {% if debug.token_rows %}
        <table>
          <thead>
            <tr>
              <th>Stage</th>
              <th>Model</th>
              <th>Tokens In</th>
              <th>Tokens Out</th>
              <th>Est. Cost</th>
            </tr>
          </thead>
          <tbody>
            {% for row in debug.token_rows %}
            <tr>
              <td>{{ row.stage }}</td>
              <td>{{ row.model }}</td>
              <td>{{ "{:,}".format(row.tokens_input) }}</td>
              <td>{{ "{:,}".format(row.tokens_output) }}</td>
              <td>${{ "%.4f"|format(row.cost) }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        {% else %}
        <p class="debug-empty">No API calls this run.</p>
        {% endif %}

        {% if debug.warn_lines %}
        <p class="debug-meta"><strong>Warnings &amp; Errors</strong></p>
        <ul class="debug-warn">
          {% for line in debug.warn_lines %}
          <li>{{ line | e }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </details>
    </div>
    {% endif %}

  </main>

</div>

{# ─── FOOTER ─── #}
<div class="disclosure-footer">
  This brief is AI-generated and requires human review before any capital commitment
  or site-selection decision. Data accuracy is not guaranteed.<br>
  Generated by CLIP · {{ brief.generated_at | e if brief.generated_at else '' }} · Ineligible market — expansion recommendations suppressed
</div>

<script>
  document.querySelectorAll('.sb-nav a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  var sections = document.querySelectorAll('.section[id]');
  var navLinks = document.querySelectorAll('.sb-nav a');
  if (sections.length && navLinks.length) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          navLinks.forEach(function(link) {
            var active = link.getAttribute('href') === '#' + entry.target.id;
            link.style.fontWeight = active ? '600' : '';
            link.style.color      = active ? 'var(--text-primary)' : '';
          });
        }
      });
    }, { threshold: 0.3 });
    sections.forEach(function(s) { observer.observe(s); });
  }
</script>

</body>
</html>
