<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ state }} Charter Market Scan — {{ date_str }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      font-size: 13px;
      color: #1a1a1a;
      background: #f8f8f8;
      padding: 24px;
    }

    h1 {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    h2 {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #374151;
    }
    .meta {
      font-size: 11px;
      color: #666;
      margin-bottom: 20px;
    }

    .section { margin-bottom: 28px; }

    .insufficient-note {
      font-size: 11px;
      color: #92400e;
      background: #fef3c7;
      border: 1px solid #fcd34d;
      border-radius: 4px;
      padding: 6px 10px;
      margin-bottom: 10px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
    }

    thead th {
      background: #1e293b;
      color: #e2e8f0;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .05em;
      padding: 10px 12px;
      text-align: left;
      white-space: nowrap;
    }
    thead th.right { text-align: right; }
    thead th.center { text-align: center; }

    tbody tr { border-bottom: 1px solid #e5e7eb; }
    tbody tr:last-child { border-bottom: none; }

    td {
      padding: 9px 12px;
      vertical-align: middle;
    }
    td.right  { text-align: right; }
    td.center { text-align: center; }
    td.rank   { font-weight: 700; color: #64748b; width: 36px; }
    td.score  { font-weight: 700; font-size: 14px; width: 64px; white-space: nowrap; }
    td.city   { font-weight: 600; min-width: 120px; }
    td.snap   { color: #374151; max-width: 280px; }
    td.tensions { color: #6b7280; font-size: 11px; max-width: 180px; }
    td.coverage { white-space: nowrap; }

    /* Tier row colouring */
    tr.tier-HIGH_PRIORITY  { background: #f0fdf4; }
    tr.tier-STRONG         { background: #eff6ff; }
    tr.tier-MODERATE       { background: #fefce8; }
    tr.tier-WATCHLIST      { background: #fff7ed; }
    tr.tier-AVOID          { background: #fef2f2; }

    /* Insufficient data table — muted rows */
    .insufficient-table tbody tr { background: #f9fafb; }

    /* Tier badge */
    .tier-badge {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 9999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .04em;
      white-space: nowrap;
    }
    .tier-HIGH_PRIORITY  .tier-badge { background: #22c55e; color: #fff; }
    .tier-STRONG         .tier-badge { background: #3b82f6; color: #fff; }
    .tier-MODERATE       .tier-badge { background: #eab308; color: #fff; }
    .tier-WATCHLIST      .tier-badge { background: #f97316; color: #fff; }
    .tier-AVOID          .tier-badge { background: #ef4444; color: #fff; }
    .insufficient-table  .tier-badge { background: #d1d5db; color: #6b7280; }

    /* Deep review badge */
    .dr-badge {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      white-space: nowrap;
    }
    .dr-strong_recommendation { background: #fee2e2; color: #991b1b; }
    .dr-recommended            { background: #ffedd5; color: #9a3412; }
    .dr-optional_review        { background: #e5e7eb; color: #374151; }

    /* Data coverage badge */
    .cov-badge {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      white-space: nowrap;
    }
    .cov-reliable    { background: #dcfce7; color: #166534; }
    .cov-provisional { background: #fef9c3; color: #854d0e; }
    .cov-unreliable  { background: #fee2e2; color: #991b1b; }

    /* ⚠ badge on score */
    .warn-badge {
      font-size: 11px;
      margin-left: 3px;
      vertical-align: middle;
    }

    /* ⚑ special considerations flag */
    .flag-badge {
      font-size: 12px;
      margin-left: 4px;
      color: #6366f1;
      cursor: help;
      vertical-align: middle;
    }

    /* SMALL_MARKET scale caveat note */
    .scale-caveat-note {
      font-size: 10px;
      color: #92400e;
      background: #fef3c7;
      border: 1px solid #fcd34d;
      border-radius: 3px;
      padding: 3px 6px;
      margin-top: 4px;
      line-height: 1.4;
      max-width: 200px;
    }

    /* Table footnote */
    .table-footnote {
      font-size: 11px;
      color: #9ca3af;
      margin-top: 6px;
      margin-bottom: 20px;
    }

    .tensions-list { list-style: none; }
    .tensions-list li::before { content: "· "; color: #9ca3af; }

    footer {
      margin-top: 16px;
      font-size: 11px;
      color: #9ca3af;
    }

    @media print {
      body { background: #fff; padding: 0; font-size: 11px; }
      table { box-shadow: none; }
      thead th { background: #1e293b !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      tr.tier-HIGH_PRIORITY,
      tr.tier-STRONG,
      tr.tier-MODERATE,
      tr.tier-WATCHLIST,
      tr.tier-AVOID { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .tier-badge, .dr-badge, .cov-badge { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
  </style>
</head>
<body>

  <h1>{{ state }} Charter Market Scan — {{ preset | title }} Preset</h1>
  <p class="meta">
    {{ city_count }} communities · ranked by composite score · generated {{ generated_at[:10] }}
  </p>

  {# Split results into reliable/provisional vs unreliable #}
  {% set ranked_results = results | selectattr("data_coverage_tier", "ne", "unreliable") | list %}
  {% set insufficient_results = results | selectattr("data_coverage_tier", "equalto", "unreliable") | list %}
  {# Fall back: if data_coverage_tier absent, treat as ranked #}
  {% set ranked_results = ranked_results + (results | rejectattr("data_coverage_tier", "defined") | list) %}

  {# ── Main ranked table ── #}
  <div class="section">
    <table>
      <thead>
        <tr>
          <th class="center">Rank</th>
          <th>City</th>
          <th class="right">Score</th>
          <th>Tier</th>
          <th>Data Coverage</th>
          <th>Snapshot</th>
          <th>Signal Tensions</th>
          <th class="center">Deep Review</th>
        </tr>
      </thead>
      <tbody>
        {% for r in ranked_results %}
        <tr class="tier-{{ r.tier or 'MODERATE' }}">
          <td class="rank center">{{ loop.index }}</td>
          <td class="city">
            {{ r.city }}
            {% if r.special_considerations %}
              <span class="flag-badge" title="{{ r.special_considerations }}">⚑</span>
            {% endif %}
          </td>
          <td class="score right">
            {{ "%.1f"|format(r.composite) if r.composite is not none else "—" }}
          </td>
          <td>
            {% set sm_flags = (r.override_flags or []) | selectattr("flag", "equalto", "SMALL_MARKET") | list %}
            {% if sm_flags | length > 0 %}
              {% set sm_flag = sm_flags[0] %}
              <span class="tier-badge">{{ (r.tier or "—") | replace("_", " ") }} ⚠ SCALE CAVEAT</span>
              <div class="scale-caveat-note">
                {{ sm_flag.triggered_by }}.
                Below viable single-school catchment under most operator models.
                Highest demand profile in the scan at this scale.
                Surfaced as a demand signal, not an actionable single-site entry.
                A regional, multi-site, or partnership model may be more appropriate than a standalone school at this location.
              </div>
            {% else %}
              <span class="tier-badge">{{ (r.tier or "—") | replace("_", " ") }}</span>
            {% endif %}
          </td>
          <td class="coverage">
            {% set cov_tier = r.data_coverage_tier or "" %}
            {% set cov_pct = r.data_coverage_pct %}
            {% if cov_tier %}
              <span class="cov-badge cov-{{ cov_tier }}">
                {% if cov_pct is not none %}{{ "%.0f"|format(cov_pct) }}%{% endif %}
                {{ cov_tier | title }}
              </span>
            {% else %}
              —
            {% endif %}
          </td>
          <td class="snap">{{ r.one_line_snapshot or "—" }}</td>
          <td class="tensions">
            {% if r.signal_tensions %}
              <ul class="tensions-list">
                {% for t in r.signal_tensions %}
                  <li>{{ t }}</li>
                {% endfor %}
              </ul>
            {% else %}
              —
            {% endif %}
          </td>
          <td class="center">
            {% set dr = r.deep_review_level or "" %}
            {% if dr == "strong_recommendation" %}
              <span class="dr-badge dr-strong_recommendation">Strong</span>
            {% elif dr == "recommended" %}
              <span class="dr-badge dr-recommended">Recommended</span>
            {% elif dr == "optional_review" %}
              <span class="dr-badge dr-optional_review">Optional</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <p class="table-footnote">† 68% provisional reflects always-defaulted dimensions (authorizer confidence, facilities) — not a data quality variance signal.</p>
  </div>

  {# ── Insufficient data section ── #}
  {% if insufficient_results %}
  <div class="section">
    <h2>Communities — Insufficient Data</h2>
    <p class="insufficient-note">
      Scores reflect limited signals only (&lt;50% verified data). Exclude from strategic ranking.
    </p>
    <table class="insufficient-table">
      <thead>
        <tr>
          <th>City</th>
          <th class="right">Score ⚠</th>
          <th>Tier</th>
          <th>Data Coverage</th>
          <th>Snapshot</th>
          <th>Signal Tensions</th>
        </tr>
      </thead>
      <tbody>
        {% for r in insufficient_results | sort(attribute="city") %}
        <tr>
          <td class="city">{{ r.city }}</td>
          <td class="score right">
            {{ "%.1f"|format(r.composite) if r.composite is not none else "—" }}
            <span class="warn-badge" title="Insufficient data — exclude from ranking">⚠</span>
          </td>
          <td>
            <span class="tier-badge">{{ (r.tier or "—") | replace("_", " ") }}</span>
          </td>
          <td class="coverage">
            {% set cov_pct = r.data_coverage_pct %}
            <span class="cov-badge cov-unreliable">
              {% if cov_pct is not none %}{{ "%.0f"|format(cov_pct) }}%{% endif %}
              Unreliable
            </span>
          </td>
          <td class="snap">{{ r.one_line_snapshot or "—" }}</td>
          <td class="tensions">
            {% if r.signal_tensions %}
              <ul class="tensions-list">
                {% for t in r.signal_tensions %}
                  <li>{{ t }}</li>
                {% endfor %}
              </ul>
            {% else %}
              —
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

  <footer>
    Scan mode · composite scores from S5 · no audit pass · weights uncalibrated.
    Deep review badge reflects tier only — not a final recommendation.
    Data coverage = share of total preset weight backed by real (non-defaulted) signals.
  </footer>

</body>
</html>
