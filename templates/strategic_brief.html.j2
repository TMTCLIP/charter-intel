<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ brief.community_name }}, {{ brief.state }} — Strategic Brief</title>
  <style>
    body { font-family: Georgia, serif; max-width: 860px; margin: 2em auto; padding: 0 1.5em; line-height: 1.6; color: #222; }
    h1 { font-size: 1.6em; margin-bottom: 0.2em; }
    h2 { font-size: 1.2em; border-bottom: 1px solid #ccc; padding-bottom: 0.2em; margin-top: 1.8em; }
    h3 { font-size: 1em; margin-bottom: 0.3em; }
    table { border-collapse: collapse; width: 100%; margin: 1em 0; }
    th, td { border: 1px solid #ccc; padding: 0.45em 0.65em; text-align: left; }
    th { background: #f2f2f2; font-weight: bold; }
    td:nth-child(2), td:nth-child(3) { text-align: right; }
    code { background: #f4f4f4; padding: 0.15em 0.35em; border-radius: 3px; font-size: 0.9em; }
    hr { border: none; border-top: 1px solid #ddd; margin: 1.5em 0; }
    ul { margin: 0.4em 0 0.8em 1.4em; padding: 0; }
    li { margin-bottom: 0.3em; }
    blockquote { border-left: 4px solid #e67e22; margin: 1em 0; padding: 0.5em 1em; background: #fdf6ec; }
    .meta { color: #555; font-size: 0.92em; }
    .disclosure { color: #666; font-size: 0.88em; font-style: italic; margin-top: 2em; }
  </style>
</head>
<body>

<h1>{{ brief.community_name }}, {{ brief.state }} — Strategic Brief</h1>
<p>
  <strong>Preset:</strong> {{ brief.preset | title }} &nbsp;&nbsp;
  <strong>Score:</strong> {{ brief.composite_score }}/10 &nbsp;&nbsp;
  <strong>Confidence:</strong> {{ brief.confidence_overall }}
</p>
<p><strong>Classification:</strong> {{ brief.classification }}</p>
<p class="meta"><em>Data through {{ brief.data_through }} · Generated {{ brief.generated_at[:10] }}</em></p>
<hr>

<h2>Executive Snapshot</h2>
<p>{{ brief.executive_snapshot }}</p>
<hr>

<h2>Scorecard</h2>
<p><strong>Composite: {{ brief.scorecard_summary.composite_score }}/10 — {{ brief.scorecard_summary.tier_display_label }}</strong></p>
<table>
  <thead>
    <tr>
      <th>Dimension</th>
      <th>Score</th>
      <th>Weight</th>
      <th>Confidence</th>
      <th>Driver</th>
    </tr>
  </thead>
  <tbody>
    {% for row in brief.scorecard_summary.dimension_table %}
    <tr>
      <td>{{ row.display_name }}</td>
      <td>{{ row.score }}</td>
      <td>{{ (row.weight * 100) | int }}%</td>
      <td>{{ row.confidence }}</td>
      <td>{{ row.driver }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

{% if brief.scorecard_summary.top_drivers %}
<p><strong>Top drivers:</strong></p>
<ul>
  {% for d in brief.scorecard_summary.top_drivers %}
  <li><strong>{{ d.dimension }}</strong> ({{ d.score }}) — {{ d.driver }}</li>
  {% endfor %}
</ul>
{% endif %}
<hr>

<h2>Override Flags</h2>
{% if brief.scorecard_summary.override_flags %}
<ul>
  {% for flag in brief.scorecard_summary.override_flags %}
  <li>{{ flag.visual }} <strong>{{ flag.flag }}</strong> — {{ flag.triggered_by }} <em>({{ flag.tier_effect }})</em></li>
  {% endfor %}
</ul>
{% else %}
<p>No override flags triggered.</p>
{% endif %}
<hr>

<h2>Recommendations</h2>
{% for rec in brief.recommendations %}
<h3>{{ loop.index }}. {{ rec.action }}</h3>
<p>{{ rec.rationale }}</p>
<p>
  <em>Evidence:</em> {{ rec.evidence_summary }}<br>
  <em>Primary risk:</em> {{ rec.primary_risk }}<br>
  <em>Confidence:</em> {{ rec.confidence }}
</p>
{% endfor %}
<hr>

<h2>Quick Reads</h2>
{% if brief.quick_reads %}
<p><strong>Facilities:</strong> {{ brief.quick_reads.facilities }}</p>
<p><strong>Political:</strong> {{ brief.quick_reads.political }}</p>
<p><strong>Authorizer:</strong> {{ brief.quick_reads.authorizer }}</p>
{% endif %}
<hr>

{% if brief.schools_to_watch %}
<h2>Schools to Watch</h2>
<ul>
  {% for s in brief.schools_to_watch %}
  <li><strong>{{ s.school_name }}</strong> <code>{{ s.flag_type }}</code> — {{ s.reason }}</li>
  {% endfor %}
</ul>
{% endif %}

<h2>Needs Verification</h2>
<ul>
  {% for item in brief.needs_verification %}
  <li>
    <strong>{{ item.claim }}</strong><br>
    <em>Why:</em> {{ item.reason }} &nbsp; <em>Impact if wrong:</em> {{ item.impact_if_wrong }} &nbsp; <em>Resolution:</em> {{ item.resolution_path }}
  </li>
  {% endfor %}
</ul>
<hr>

<h2>Sources</h2>
<ul>
  {% for s in brief.sources %}
  <li>
    [{{ s.ref_num }}] {{ s.title }} · {{ s.source_class }}{% if s.url %} · <a href="{{ s.url }}">{{ s.url }}</a>{% endif %}{% if s.date %} · {{ s.date }}{% endif %}
  </li>
  {% endfor %}
</ul>
<hr>

{% if brief.audit_passed == false %}
<blockquote>
  <p>⚠️ <strong>Audit flag:</strong> {{ brief.audit_flags | length }} claim(s) flagged by hallucination audit. Review before external use.</p>
  <ul>
    {% for f in brief.audit_flags %}
    <li><code>{{ f.location }}</code>: {{ f.claim_text[:80] }}… <em>({{ f.recommended_action }})</em></li>
    {% endfor %}
  </ul>
</blockquote>
{% endif %}

<p class="disclosure">{{ brief.disclosure }}</p>

</body>
</html>
