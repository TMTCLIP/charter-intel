# Ignore all generated outputs EXCEPT the committed POC demo brief (nm-questa).
# A blanket `outputs/` dir-exclusion cannot be negated for a nested path, so we
# exclude contents level-by-level and re-include the nm-questa path.
outputs/*
!outputs/by_community/
outputs/by_community/*
!outputs/by_community/nm-questa/
!outputs/by_community/nm-questa/**

clip_ops/state.json
clip_ops/backlog_ranked.json
clip_ops/daily_digest.md
clip_ops/email.log
clip_ops/run_daily.log
