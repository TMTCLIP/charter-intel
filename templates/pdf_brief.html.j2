<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ brief.community_name | e }}, {{ brief.state | e }} — CLIP Brief</title>
  <style>
    @page {
      size: Letter;
      margin: 0.6in 0.7in;
    }

    :root {
      --bg-primary:       #0d1117;
      --bg-secondary:     #161b22;
      --bg-card:          #1c2128;
      --border-subtle:    rgba(255,255,255,0.08);
      --border-muted:     rgba(255,255,255,0.15);
      --text-primary:     #e6edf3;
      --text-secondary:   #8b949e;
      --text-muted:       #6e7681;
      --accent-green:     #3fb950;
      --accent-yellow:    #d29922;
      --accent-red:       #f85149;
      --accent-blue:      #58a6ff;
      --accent-orange:    #f0883e;
      --score-green:      #3fb950;
      --score-green-bg:   rgba(63,185,80,0.12);
      --score-yellow:     #d29922;
      --score-yellow-bg:  rgba(210,153,34,0.12);
      --score-red:        #f85149;
      --score-red-bg:     rgba(248,81,73,0.12);
      --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      --font-mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      --font-serif: Georgia, 'Times New Roman', serif;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }

    body {
      font-family: var(--font-sans);
      font-size: 11px;
      line-height: 1.55;
      color: var(--text-primary);
      background: var(--bg-primary);
    }

    /* ── PDF header ── */
    .pdf-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding-bottom: 14px;
      border-bottom: 2px solid var(--border-muted);
      margin-bottom: 18px;
      page-break-inside: avoid;
    }

    .pdf-wordmark {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 5px;
    }

    .pdf-community {
      font-family: var(--font-serif);
      font-size: 22px;
      line-height: 1.15;
      color: var(--text-primary);
    }

    .pdf-state-label {
      font-size: 11px;
      color: var(--text-secondary);
      font-weight: 300;
      margin-top: 3px;
    }

    .pdf-header-right { text-align: right; }

    .pdf-score-num {
      font-family: var(--font-serif);
      font-size: 36px;
      line-height: 1;
    }
    .pdf-score-max {
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 300;
      color: var(--text-muted);
    }
    .pdf-score-tier {
      font-size: 10px;
      color: var(--text-secondary);
      margin-top: 2px;
    }
    .pdf-meta {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--text-muted);
      margin-top: 7px;
      line-height: 1.6;
    }

    /* ── Confidence pill ── */
    .conf-pill {
      display: inline-block;
      border-radius: 999px;
      padding: 2px 8px;
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
    }
    .conf-high     { background: rgba(88,166,255,0.12); color: var(--accent-blue); border: 1px solid rgba(88,166,255,0.25); }
    .conf-moderate { background: transparent; color: var(--text-secondary); border: 1px solid var(--border-muted); }
    .conf-low      { background: transparent; color: var(--text-muted); border: 1px solid var(--border-subtle); font-style: italic; }

    /* ── Verdict bar ── */
    .verdict-bar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 6px;
      margin-bottom: 16px;
      page-break-inside: avoid;
    }
    .verdict-bar-green  { background: var(--score-green-bg);  border: 1px solid rgba(63,185,80,0.3); }
    .verdict-bar-yellow { background: var(--score-yellow-bg); border: 1px solid rgba(210,153,34,0.3); }
    .verdict-bar-red    { background: var(--score-red-bg);    border: 1px solid rgba(248,81,73,0.3); }

    .verdict-label {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .verdict-green  { color: var(--score-green); }
    .verdict-yellow { color: var(--score-yellow); }
    .verdict-red    { color: var(--score-red); }
    .verdict-emerging { font-size: 10px; color: var(--accent-blue); }

    /* ── Sections ── */
    .section { margin-top: 22px; }

    .section-label {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 10px;
      padding-bottom: 5px;
      border-bottom: 1px solid var(--border-subtle);
    }

    /* ── Banners ── */
    .banner {
      border-radius: 6px;
      padding: 10px 14px;
      margin-bottom: 12px;
      border-left: 3px solid;
      font-size: 11px;
      line-height: 1.55;
      page-break-inside: avoid;
    }
    .banner strong { display: block; margin-bottom: 2px; font-weight: 700; }
    .banner-insufficient { background: var(--score-yellow-bg); border-color: var(--score-yellow); color: #e3c86d; }
    .banner-gate         { background: var(--score-red-bg);    border-color: var(--score-red);    color: #f9a09b; }
    .banner-tribal       { background: rgba(88,166,255,0.07);  border-color: var(--accent-blue);  color: #a2c5f2; }
    .banner-pci-legacy   { background: rgba(240,136,62,0.10);  border-color: var(--accent-orange);color: #f5b07a; }

    /* ── Statutory barrier ── */
    .statutory-box {
      border-radius: 6px;
      padding: 12px 14px;
      margin-bottom: 14px;
      page-break-inside: avoid;
    }
    .statutory-box-prohib  { border: 2px solid #b00020; background: rgba(176,0,32,0.08); }
    .statutory-box-barrier { border: 2px solid #b76e00; background: rgba(183,110,0,0.08); }
    .statutory-title-prohib  { font-weight: 800; font-size: 12px; letter-spacing: .03em; color: #f9a09b; margin-bottom: 6px; }
    .statutory-title-barrier { font-weight: 800; font-size: 12px; letter-spacing: .03em; color: #f5c67a; margin-bottom: 6px; }
    .statutory-body   { font-size: 11px; line-height: 1.5; color: var(--text-secondary); }
    .statutory-statute { font-size: 10px; margin-top: 6px; color: var(--text-muted); }
    .statutory-note   { font-size: 10px; margin-top: 4px; color: var(--text-muted); font-style: italic; }

    /* ── Executive snapshot ── */
    .exec-snapshot {
      font-size: 12px;
      line-height: 1.75;
      color: var(--text-primary);
      font-weight: 300;
    }

    /* ── Score bars ── */
    .composite-line {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 14px;
    }

    .bar-row {
      padding: 10px 0;
      border-bottom: 1px solid var(--border-subtle);
      page-break-inside: avoid;
    }
    .bar-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 6px;
    }
    .bar-name  { font-size: 11px; font-weight: 600; color: var(--text-primary); }
    .bar-score { font-family: var(--font-mono); font-size: 12px; font-weight: 700; }

    .bar-track {
      background: rgba(255,255,255,0.06);
      height: 4px;
      border-radius: 2px;
      overflow: hidden;
      margin-bottom: 5px;
    }
    .bar-fill { height: 4px; border-radius: 2px; }

    .fill-green    { background: var(--score-green); }
    .fill-yellow   { background: var(--score-yellow); }
    .fill-red      { background: var(--score-red); }
    .fill-excluded { background: var(--text-muted); opacity: 0.35; }
    .fill-awaiting { background: var(--text-muted); opacity: 0.15; }

    .txt-green  { color: var(--score-green); }
    .txt-yellow { color: var(--score-yellow); }
    .txt-red    { color: var(--score-red); }
    .txt-muted  { color: var(--text-muted); }

    .bar-weight { font-family: var(--font-mono); font-size: 9px; color: var(--text-muted); }
    .bar-driver { font-size: 10px; color: var(--text-secondary); margin-top: 3px; }

    .awaiting-label { font-size: 10px; font-style: italic; color: var(--text-muted) !important; font-weight: 400 !important; font-family: var(--font-sans); }
    .awaiting-note  { font-size: 10px; color: var(--text-muted); font-style: italic; margin-left: 3px; }

    .nullweight-pill {
      display: inline-block;
      background: transparent;
      border: 1px solid var(--border-subtle);
      color: var(--text-muted);
      border-radius: 999px;
      padding: 1px 6px;
      font-family: var(--font-mono);
      font-size: 9px;
      margin-right: 6px;
    }

    .excluded-sep {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--text-muted);
      margin: 16px 0 6px;
      letter-spacing: 0.06em;
    }

    /* ── Top drivers ── */
    .driver-item {
      border-left: 2px solid var(--accent-blue);
      padding-left: 10px;
      margin-bottom: 8px;
      font-size: 11px;
      color: var(--text-secondary);
      page-break-inside: avoid;
    }
    .driver-item strong { color: var(--text-primary); }

    /* ── Override flags ── */
    .flag-card {
      border-radius: 6px;
      border-left: 3px solid;
      padding: 10px 13px;
      margin-bottom: 8px;
      page-break-inside: avoid;
    }
    .flag-card .flag-head { font-size: 11px; font-weight: 700; margin-bottom: 2px; }
    .flag-card .flag-body { font-size: 10px; color: var(--text-secondary); }
    .flag-green   { background: var(--score-green-bg);  border-color: var(--score-green); }
    .flag-amber   { background: var(--score-yellow-bg); border-color: var(--score-yellow); }
    .flag-red     { background: var(--score-red-bg);    border-color: var(--score-red); }
    .flag-neutral { background: var(--bg-card);         border-color: var(--border-muted); }

    /* ── Greenfield notice ── */
    .greenfield-notice {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 6px;
      padding: 14px 16px;
      page-break-inside: avoid;
    }
    .greenfield-notice-icon { font-size: 16px; color: var(--text-muted); flex-shrink: 0; }
    .greenfield-notice-text { font-size: 11px; color: var(--text-muted); font-style: italic; line-height: 1.65; }

    /* ── School rows ── */
    .school-row {
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 6px;
      padding: 10px 13px;
      margin-bottom: 8px;
      page-break-inside: avoid;
    }
    .school-name { font-size: 11px; font-weight: 700; color: var(--text-primary); }
    .school-sub  { font-size: 10px; color: var(--text-secondary); margin-top: 2px; }
    .school-warn { font-size: 9px; color: var(--text-muted); font-style: italic; margin-top: 4px; }

    /* ── Authorizers ── */
    .auth-item { font-size: 11px; padding-left: 12px; margin-bottom: 7px; color: var(--text-secondary); }
    .auth-item .dash { color: var(--text-muted); margin-right: 3px; }
    .auth-item strong { color: var(--text-primary); }

    /* ── Recommendations ── */
    ol { padding-left: 16px; }
    ol li { padding-left: 4px; }
    .rec-item { font-size: 11px; margin-bottom: 10px; color: var(--text-secondary); page-break-inside: avoid; }
    .rec-item strong { color: var(--text-primary); }

    /* ── Quick reads ── */
    .qr-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
    .qr-card {
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 6px;
      padding: 10px 12px;
      page-break-inside: avoid;
    }
    .qr-label { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 4px; }
    .qr-body  { font-size: 10px; color: var(--text-secondary); line-height: 1.55; }

    /* ── Needs verification ── */
    .nv-item {
      border-left: 2px solid var(--score-yellow);
      padding-left: 10px;
      font-size: 11px;
      margin-bottom: 7px;
      color: var(--text-secondary);
      page-break-inside: avoid;
    }
    .nv-item strong { color: var(--text-primary); }

    /* ── Data sources ── */
    .src-table { width: 100%; border-collapse: collapse; font-size: 10px; }
    .src-table th {
      text-align: left;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border-muted);
      padding: 5px 7px;
      font-weight: 600;
    }
    .src-table td {
      padding: 5px 7px;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border-subtle);
    }
    .src-table tr:last-child td { border-bottom: none; }

    .muted-note { color: var(--text-muted); font-style: italic; font-size: 11px; }

    /* ── Footer ── */
    .pdf-footer {
      margin-top: 28px;
      padding-top: 10px;
      border-top: 1px solid var(--border-subtle);
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--text-muted);
      line-height: 1.7;
    }
  </style>
</head>
<body>

{% set comp = brief.composite_score if brief.composite_score is not none else 0 %}
{% set comp_tone = 'green' if comp >= 7.0 else ('yellow' if comp >= 4.0 else 'red') %}
{% set market_type = brief.market_type if brief.market_type is defined else 'established' %}
{% set _sb = brief.statutory_barrier if brief.statutory_barrier is defined else none %}
{% set _prohib = (_sb and _sb.severity == 'prohibition' and _sb.applies == true) %}
{% set sc = brief.scorecard_summary %}

{# ── PDF header ── #}
<header class="pdf-header">
  <div>
    <div class="pdf-wordmark">CLIP · Charter Intel Platform</div>
    <div class="pdf-community">{{ brief.community_name | e }}</div>
    <div class="pdf-state-label">{{ brief.state | e }}
      {%- if brief.mode_label %} · {{ brief.mode_label | e }}{% endif -%}
    </div>
  </div>
  <div class="pdf-header-right">
    <div>
      <span class="pdf-score-num txt-{{ comp_tone }}">{{ comp }}</span><span class="pdf-score-max">/10</span>
    </div>
    <div class="pdf-score-tier">{{ sc.tier_display_label | e }}</div>
    {% set co = (brief.confidence_overall or '') | upper %}
    <div style="margin-top:5px;">
      {% if co == 'HIGH' %}<span class="conf-pill conf-high">Confidence: High</span>
      {% elif co == 'MODERATE' %}<span class="conf-pill conf-moderate">Confidence: Moderate</span>
      {% elif co == 'LOW' %}<span class="conf-pill conf-low">Confidence: Low</span>{% endif %}
    </div>
    <div class="pdf-meta">
      Data through {{ brief.data_through | e }}<br>
      {{ brief.generated_at | e if brief.generated_at else '' }}
    </div>
  </div>
</header>

{# ── Verdict / classification bar ── #}
{% if brief.classification %}
<div class="verdict-bar verdict-bar-{{ comp_tone }}">
  <span class="verdict-label verdict-{{ comp_tone }}">{{ brief.classification | e }}</span>
  {% if market_type == 'greenfield' %}<span class="verdict-emerging">· Emerging Market</span>{% endif %}
</div>
{% endif %}

{# ── Statutory barrier ── #}
{% if _sb %}
<div class="statutory-box {{ 'statutory-box-prohib' if _prohib else 'statutory-box-barrier' }}">
  <div class="{{ 'statutory-title-prohib' if _prohib else 'statutory-title-barrier' }}">
    {% if _prohib %}&#x26A0; STATUTORY PROHIBITION — CHARTER SCHOOLS CANNOT BE BUILT HERE
    {% else %}&#x26A0; STATUTORY BARRIER — LOCAL BOARD APPROVAL REQUIRED{% endif %}
  </div>
  <div class="statutory-body">{{ _sb.banner_text | e }}</div>
  {% if _sb.statute %}<div class="statutory-statute"><strong>Statute:</strong> {{ _sb.statute | e }}</div>{% endif %}
  {% if not _sb.evaluable %}<div class="statutory-note">District accountability rating not verified in-pipeline — this barrier may or may not apply. Confirm the district's current rating.</div>{% endif %}
  <div class="statutory-note">Verify current law before strategic use.</div>
</div>
{% endif %}

{# ── Banners ── #}
{% if brief.data_coverage_tier == "INSUFFICIENT" %}
<div class="banner banner-insufficient">
  <strong>&#x26A0; Insufficient data coverage</strong>
  Four or more scoring dimensions defaulted to midpoint. Treat rankings and recommendations below as research directions, not confident calls.
</div>
{% endif %}

{% if brief.recommendation_confidence_gate and brief.recommendation_confidence_gate.gated %}
<div class="banner banner-gate">
  <strong>&#x1F6AB; Recommendation confidence: gated</strong>
  {{ brief.recommendation_confidence_gate.reason | e }}
</div>
{% endif %}

{% if brief.tribal_jurisdiction_flag is defined and brief.tribal_jurisdiction_flag %}
<div class="banner banner-tribal">
  <strong>&#x2139; Tribal jurisdiction: {{ (brief.tribal_jurisdiction_flag.status or '') | replace("_", " ") | e }}</strong>
  {{ brief.tribal_jurisdiction_flag.note | e }}
  {% if brief.tribal_jurisdiction_flag.resolution_path %}<br><em>Resolution:</em> {{ brief.tribal_jurisdiction_flag.resolution_path | e }}{% endif %}
</div>
{% endif %}

{% if pci_promoted %}
<div class="banner banner-pci-legacy">
  <strong>&#x26A0; Political climate score recovered from legacy cache.</strong>
  Confidence reduced — re-run S3 to generate a fresh signal.
</div>
{% endif %}

{# ── Executive snapshot ── #}
<div class="section">
  <p class="section-label">Executive Snapshot</p>
  <p class="exec-snapshot">{{ brief.executive_snapshot | e }}</p>
</div>

{# ── Scorecard ── #}
{% if not _prohib %}
<div class="section">
  <p class="section-label">Scorecard</p>
  <p class="composite-line">Composite: {{ sc.composite_score }}/10 — {{ sc.tier_display_label | e }}</p>

  {% for row in sc.dimension_table if not row.used_default %}
  {% set tone = 'green' if row.score >= 7.0 else ('yellow' if row.score >= 4.0 else 'red') %}
  <div class="bar-row">
    <div class="bar-head">
      <span class="bar-name">{{ row.display_name | e }}</span>
      <span class="bar-score txt-{{ tone }}">{{ row.score }}</span>
    </div>
    <div class="bar-track">
      <div class="bar-fill fill-{{ tone }}" style="width: {{ '%.0f' | format(row.score / 10 * 100) }}%;"></div>
    </div>
    <div class="bar-weight">{{ (row.weight * 100) | int }}% weight</div>
    {% if row.driver %}<div class="bar-driver">{{ row.driver | e }}</div>{% endif %}
  </div>
  {% endfor %}

  {% set excluded = sc.dimension_table | selectattr("used_default") | list %}
  {% if excluded %}
  <div class="excluded-sep">─── Excluded from composite ───</div>
  {% for row in excluded %}
  {% if row.dimension == 'academic_need' %}
  <div class="bar-row">
    <div class="bar-head">
      <span class="bar-name txt-muted">{{ row.display_name | e }}</span>
      <span class="awaiting-label">Awaiting Data</span>
    </div>
    <div class="bar-track"><div class="bar-fill fill-awaiting" style="width:50%;"></div></div>
    <div class="bar-driver">
      <span class="nullweight-pill">no data</span><span class="awaiting-note">No proficiency data available for this state</span>
    </div>
  </div>
  {% else %}
  <div class="bar-row">
    <div class="bar-head">
      <span class="bar-name txt-muted">{{ row.display_name | e }}</span>
      <span class="bar-score txt-muted">{{ row.score }}</span>
    </div>
    <div class="bar-track"><div class="bar-fill fill-excluded" style="width: {{ '%.0f' | format(row.score / 10 * 100) }}%;"></div></div>
    <div class="bar-driver">
      <span class="nullweight-pill">0% weight — not scored</span>{% if row.driver %}{{ row.driver | e }}{% endif %}
    </div>
  </div>
  {% endif %}
  {% endfor %}
  {% endif %}

  {% if sc.excluded_dimensions %}
  <p class="bar-weight" style="margin-top:10px;">
    Excluded dimensions default to 5.0 and are removed from the composite; weight redistributed proportionally.
    Excluded: {{ sc.excluded_dimensions | join(", ") | e }}.
  </p>
  {% endif %}
</div>
{% endif %}{# /not _prohib #}

{# ── Top drivers ── #}
{% if sc.top_drivers %}
<div class="section">
  <p class="section-label">Top Drivers</p>
  {% for d in sc.top_drivers %}
  <div class="driver-item"><strong>{{ d.dimension | e }}</strong> ({{ d.score }}) — {{ d.driver | e }}</div>
  {% endfor %}
</div>
{% endif %}

{# ── Override flags ── #}
<div class="section">
  <p class="section-label">Override Flags</p>
  {% if sc.override_flags %}
  {% for flag in sc.override_flags %}
  {% set ftxt = ((flag.tier_effect or '') ~ ' ' ~ (flag.flag or '')) | lower %}
  {% if 'positive' in ftxt or 'friendly' in ftxt or 'boost' in ftxt %}
    {% set ftone = 'green' %}{% set ficon = '&#x2705;' %}
  {% elif 'hard' in ftxt or 'negative' in ftxt or 'penalty' in ftxt %}
    {% set ftone = 'red' %}{% set ficon = '&#x26A0;' %}
  {% elif 'cap' in ftxt %}
    {% set ftone = 'amber' %}{% set ficon = '&#x26A0;' %}
  {% else %}
    {% set ftone = 'neutral' %}{% set ficon = '&#x2139;' %}
  {% endif %}
  <div class="flag-card flag-{{ ftone }}">
    <div class="flag-head">{{ ficon }} {{ flag.flag | e }}</div>
    <div class="flag-body">{{ flag.triggered_by | e }}{% if flag.tier_effect %} <em>({{ flag.tier_effect | e }})</em>{% endif %}</div>
  </div>
  {% endfor %}
  {% else %}
  <p class="muted-note">No override flags triggered.</p>
  {% endif %}
</div>

{# ── Charter landscape ── #}
<div class="section">
  <p class="section-label">Charter Landscape</p>
  {% if market_type == 'greenfield' %}
  <div class="greenfield-notice">
    <div class="greenfield-notice-icon">&#9675;</div>
    <div class="greenfield-notice-text">
      No established charter landscape identified. School-level metrics will appear
      here once charter schools operate in this community.
    </div>
  </div>
  {% else %}
  {% set school_list = schools if schools else (brief.schools_to_watch if brief.schools_to_watch is defined else []) %}
  {% if school_list %}
  {% for s in school_list %}
  <div class="school-row">
    <div class="school-name">{{ (s.school_name or '—') | e }}</div>
    <div class="school-sub">
      {{ s.grades_served | e if s.grades_served else '' -}}
      {% if s.academic_model %} · {{ s.academic_model | e }}{% endif %}
      {%- if s.ela_proficiency_pct is not none %} · ELA {{ s.ela_proficiency_pct }}%{% endif %}
      {%- if s.math_proficiency_pct is not none %} · Math {{ s.math_proficiency_pct }}%{% endif %}
      {%- if s.proficiency_year %} ({{ s.proficiency_year }}){% endif %}
    </div>
    {% if s.notable_note %}<div class="school-sub" style="margin-top:2px; font-style:italic;">{{ s.notable_note | e }}</div>{% endif %}
    <div class="school-warn">&#x26A0; Contact info requires human verification</div>
  </div>
  {% endfor %}
  {% else %}
  <p class="muted-note">No charter school data available.</p>
  {% endif %}
  {% endif %}
</div>

{# ── Local authorizers ── #}
<div class="section">
  <p class="section-label">Local Authorizers</p>
  {% if brief.local_authorizers %}
  {% for a in brief.local_authorizers %}
  <div class="auth-item">
    <span class="dash">—</span> <strong>{{ a.authorizer_name | e }}</strong>{% if a.type %} ({{ a.type | e }}){% endif %}{% if a.reputation_note %} — {{ a.reputation_note | e }}{% endif %}
  </div>
  {% endfor %}
  {% else %}
  <p class="muted-note">No local authorizer data available.</p>
  {% endif %}
</div>

{# ── Recommendations ── #}
{% if not _prohib %}
<div class="section">
  <p class="section-label">Recommendations</p>
  {% if brief.recommendation_confidence_gate and brief.recommendation_confidence_gate.gated %}
  <div class="banner banner-gate">
    <strong>&#x1F6AB; Recommendations suppressed</strong>
    Confidence gate active — {{ brief.recommendation_confidence_gate.reason | e }}
  </div>
  {% endif %}
  {% if brief.recommendations %}
  <ol>
    {% for rec in brief.recommendations %}
    <li class="rec-item">
      <strong>{{ rec.action | e }}</strong> — {{ rec.rationale | e }}<br>
      <span class="txt-muted" style="font-size:10px;"><em>Evidence:</em> {{ rec.evidence_summary | e }} · <em>Risk:</em> {{ rec.primary_risk | e }} · <em>Confidence:</em> {{ rec.confidence | e }}</span>
    </li>
    {% endfor %}
  </ol>
  {% else %}
  <p class="muted-note">No recommendations available.</p>
  {% endif %}
</div>
{% endif %}{# /not _prohib #}

{# ── Quick reads ── #}
{% if brief.quick_reads %}
<div class="section">
  <p class="section-label">Quick Reads</p>
  <div class="qr-grid">
    <div class="qr-card">
      <div class="qr-label">Facilities</div>
      <div class="qr-body">{{ brief.quick_reads.facilities | e }}</div>
    </div>
    <div class="qr-card">
      <div class="qr-label">Political</div>
      <div class="qr-body">{{ brief.quick_reads.political | e }}</div>
    </div>
    <div class="qr-card">
      <div class="qr-label">Authorizer</div>
      <div class="qr-body">{{ brief.quick_reads.authorizer | e }}</div>
    </div>
  </div>
</div>
{% endif %}

{# ── Needs verification ── #}
{% if brief.needs_verification %}
<div class="section">
  <p class="section-label">Needs Verification</p>
  {% for item in brief.needs_verification %}
  <div class="nv-item">
    <strong>{{ item.claim | e }}</strong> — {{ item.reason | e }}
    {% if item.impact_if_wrong %}<em>(Impact: {{ item.impact_if_wrong | e }})</em>{% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}

{# ── Data sources ── #}
{% if brief.data_sources is defined and brief.data_sources %}
<div class="section">
  <p class="section-label">Data Sources &amp; Confidence</p>
  <table class="src-table">
    <thead>
      <tr>
        <th>Source</th><th>Powers</th><th>Vintage</th><th>Status</th>
      </tr>
    </thead>
    <tbody>
      {% for d in brief.data_sources %}
      {% set _c = 'var(--accent-green)' if d.status_icon == '✓' else ('var(--accent-yellow)' if d.status_icon == '⚠' else 'var(--accent-red)') %}
      <tr>
        <td style="color:var(--text-primary);">{{ d.source | e }}</td>
        <td>{{ d.powers | e }}</td>
        <td>{{ d.vintage | e }}</td>
        <td style="color:{{ _c }}; white-space:nowrap;">{{ d.status_icon }} {{ d.status | e }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

{# ── Footer ── #}
<div class="pdf-footer">
  This brief is AI-generated and requires human review before any capital commitment or site-selection decision. Data accuracy is not guaranteed.<br>
  Generated by CLIP · {{ brief.generated_at | e if brief.generated_at else '' }} · Draft — verify before distribution
</div>

</body>
</html>
