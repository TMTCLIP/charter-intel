<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ brief.community_name }}, {{ brief.state }} — Strategic Brief</title>
  <style>
    body { font-family: Georgia, serif; max-width: 860px; margin: 2em auto; padding: 0 1.5em; line-height: 1.6; color: #222; }
    h1 { font-size: 1.6em; margin-bottom: 0.2em; }
    h2 { font-size: 1.2em; border-bottom: 1px solid #ccc; padding-bottom: 0.2em; margin-top: 1.8em; }
    h3 { font-size: 1em; margin-bottom: 0.3em; }
    table { border-collapse: collapse; width: 100%; margin: 1em 0; }
    th, td { border: 1px solid #ccc; padding: 0.45em 0.65em; text-align: left; }
    th { background: #f2f2f2; font-weight: bold; }
    td:nth-child(2), td:nth-child(3) { text-align: right; }
    code { background: #f4f4f4; padding: 0.15em 0.35em; border-radius: 3px; font-size: 0.9em; }
    hr { border: none; border-top: 1px solid #ddd; margin: 1.5em 0; }
    ul { margin: 0.4em 0 0.8em 1.4em; padding: 0; }
    li { margin-bottom: 0.3em; }
    blockquote { border-left: 4px solid #e67e22; margin: 1em 0; padding: 0.5em 1em; background: #fdf6ec; }
    .meta { color: #555; font-size: 0.92em; }
    .disclosure { color: #666; font-size: 0.88em; font-style: italic; margin-top: 2em; }
    .banner { border-left: 5px solid; padding: 0.7em 1em; margin: 1em 0; border-radius: 4px; font-size: 0.95em; }
    .banner strong { display: block; margin-bottom: 0.2em; }
    .banner-insufficient { background: #fef2f2; border-color: #991b1b; color: #7f1d1d; }
    .banner-gate { background: #fffbeb; border-color: #b45309; color: #7c2d12; }
    .banner-tribal { background: #eff6ff; border-color: #1d4ed8; color: #1e3a8a; }
    .banner-tribal-pending { background: #fffbeb; border-color: #d97706; color: #78350f; }
    @media screen {
      .debug-section { margin-top: 3em; padding-top: 1em; border-top: 2px dashed #bbb; }
      .debug-section details > summary {
        cursor: pointer; color: #888; font-size: 0.82em;
        font-family: monospace; user-select: none; list-style: none;
      }
      .debug-section details > summary::before { content: "▶ "; }
      .debug-section details[open] > summary::before { content: "▼ "; }
      .debug-section details[open] > summary { margin-bottom: 0.8em; }
      .debug-meta { font-size: 0.8em; color: #999; font-family: monospace; margin: 0.4em 0; }
      .debug-section table { font-size: 0.8em; color: #777; margin: 0.6em 0; }
      .debug-section th { background: #f8f8f8; color: #666; font-weight: normal; }
      .debug-section td { color: #777; }
      .debug-section td:nth-child(3),
      .debug-section td:nth-child(4),
      .debug-section td:nth-child(5) { text-align: right; }
      .debug-warn { font-size: 0.78em; color: #a05000; font-family: monospace;
                    margin: 0.6em 0; padding: 0; list-style: none; }
      .debug-warn li { margin-bottom: 0.25em; }
      .debug-empty { font-size: 0.8em; color: #aaa; font-style: italic; }
    }
    @media print {
      .debug-section { display: none; }
    }
  </style>
</head>
<body>

<h1>{{ brief.community_name }}, {{ brief.state }} — Strategic Brief</h1>
<p>
  <strong>Preset:</strong> {{ brief.preset | title }} &nbsp;&nbsp;
  <strong>Score:</strong> {{ brief.composite_score }}/10 &nbsp;&nbsp;
  <strong>Confidence:</strong> {{ brief.confidence_overall }}
</p>
<p><strong>Classification:</strong> {{ brief.classification }}</p>
<p class="meta"><em>Data through {{ brief.data_through }} · Generated {{ brief.generated_at[:10] }}</em></p>

{% if brief.data_coverage_tier == "INSUFFICIENT" %}
<div class="banner banner-insufficient">
  <strong>⚠ Insufficient data coverage</strong>
  Four or more scoring dimensions defaulted to midpoint. The composite score is
  largely a redistribution of default values rather than evidence. Treat the
  ranking and recommendations below as research directions, not confident calls.
</div>
{% endif %}

{% if brief.recommendation_confidence_gate and brief.recommendation_confidence_gate.gated and brief.data_coverage_tier != "INSUFFICIENT" %}
<div class="banner banner-gate">
  <strong>Recommendation confidence: gated</strong>
  {{ brief.recommendation_confidence_gate.reason }}
</div>
{% endif %}

{% if brief.tribal_jurisdiction_flag %}
{% if brief.tribal_jurisdiction_flag.status == "PENDING_HUMAN_REVIEW" %}
<div class="banner banner-tribal-pending">
  <strong>⚑ Tribal jurisdiction determination pending — human review required before strategic use</strong>
  {{ brief.tribal_jurisdiction_flag.note }}
  {% if brief.tribal_jurisdiction_flag.resolution_path %}<br><em>Resolution:</em> {{ brief.tribal_jurisdiction_flag.resolution_path }}{% endif %}
</div>
{% else %}
<div class="banner banner-tribal">
  <strong>⚑ Tribal jurisdiction: {{ brief.tribal_jurisdiction_flag.status | replace("_", " ") }}</strong>
  {{ brief.tribal_jurisdiction_flag.note }}
  {% if brief.tribal_jurisdiction_flag.resolution_path %}<br><em>Resolution:</em> {{ brief.tribal_jurisdiction_flag.resolution_path }}{% endif %}
</div>
{% endif %}
{% endif %}
<hr>

<h2>Executive Snapshot</h2>
<p>{{ brief.executive_snapshot }}</p>
<hr>

<h2>Scorecard</h2>
<p><strong>Composite: {{ brief.scorecard_summary.composite_score }}/10 — {{ brief.scorecard_summary.tier_display_label }}</strong></p>
<table>
  <thead>
    <tr>
      <th>Dimension</th>
      <th>Score</th>
      <th>Weight</th>
      <th>Confidence</th>
      <th>Driver</th>
    </tr>
  </thead>
  <tbody>
    {% for row in brief.scorecard_summary.dimension_table %}
    {% if row.used_default %}
    <tr style="color: #888;">
      <td>{{ row.display_name }}</td>
      <td>{{ row.score }}*</td>
      <td>{{ (row.weight * 100) | int }}%</td>
      <td><em>(excluded — no data)</em></td>
      <td>{{ row.driver }}</td>
    </tr>
    {% else %}
    <tr>
      <td>{{ row.display_name }}</td>
      <td>{{ row.score }}</td>
      <td>{{ (row.weight * 100) | int }}%</td>
      <td>{{ row.confidence }}</td>
      <td>{{ row.driver }}</td>
    </tr>
    {% endif %}
    {% endfor %}
  </tbody>
</table>
{% if brief.scorecard_summary.excluded_dimensions %}
<p style="font-size: 0.85em; color: #888;">
  * Score shown for reference only. Dimensions marked <em>(excluded — no data)</em>
  default to 5.0 and are excluded from the composite; their weight is redistributed
  proportionally across scored dimensions.
  Excluded: {{ brief.scorecard_summary.excluded_dimensions | join(", ") }}.
</p>
{% endif %}

{% if brief.scorecard_summary.top_drivers %}
<p><strong>Top drivers:</strong></p>
<ul>
  {% for d in brief.scorecard_summary.top_drivers %}
  <li><strong>{{ d.dimension }}</strong> ({{ d.score }}) — {{ d.driver }}</li>
  {% endfor %}
</ul>
{% endif %}
<hr>

<h2>Override Flags</h2>
{% if brief.scorecard_summary.override_flags %}
<ul>
  {% for flag in brief.scorecard_summary.override_flags %}
  <li>{{ flag.visual }} <strong>{{ flag.flag }}</strong> — {{ flag.triggered_by }} <em>({{ flag.tier_effect }})</em></li>
  {% endfor %}
</ul>
{% else %}
<p>No override flags triggered.</p>
{% endif %}
<hr>

<h2>Recommendations</h2>
{% for rec in brief.recommendations %}
<h3>{{ loop.index }}. {{ rec.action }}</h3>
<p>{{ rec.rationale }}</p>
<p>
  <em>Evidence:</em> {{ rec.evidence_summary }}<br>
  <em>Primary risk:</em> {{ rec.primary_risk }}<br>
  <em>Confidence:</em> {{ rec.confidence }}
</p>
{% endfor %}
<hr>

<h2>Quick Reads</h2>
{% if brief.quick_reads %}
<p><strong>Facilities:</strong> {{ brief.quick_reads.facilities }}</p>
<p><strong>Political:</strong> {{ brief.quick_reads.political }}</p>
<p><strong>Authorizer:</strong> {{ brief.quick_reads.authorizer }}</p>
{% endif %}
<hr>

{% if brief.schools_to_watch %}
<h2>Schools to Watch</h2>
<ul>
  {% for s in brief.schools_to_watch %}
  <li><strong>{{ s.school_name }}</strong> <code>{{ s.flag_type }}</code> — {{ s.reason }}</li>
  {% endfor %}
</ul>
{% endif %}

<h2>Needs Verification</h2>
<ul>
  {% for item in brief.needs_verification %}
  <li>
    <strong>{{ item.claim }}</strong><br>
    <em>Why:</em> {{ item.reason }} &nbsp; <em>Impact if wrong:</em> {{ item.impact_if_wrong }} &nbsp; <em>Resolution:</em> {{ item.resolution_path }}
  </li>
  {% endfor %}
</ul>
<hr>

<h2>Sources</h2>
<ul>
  {% for s in brief.sources %}
  <li>
    [{{ s.ref_num }}] {{ s.title }} · {{ s.source_class }}{% if s.url %} · <a href="{{ s.url }}">{{ s.url }}</a>{% endif %}{% if s.date %} · {{ s.date }}{% endif %}
  </li>
  {% endfor %}
</ul>
<hr>

{% if brief.audit_passed == false %}
<blockquote>
  <p>⚠️ <strong>Audit flag:</strong> {{ brief.audit_flags | length }} claim(s) flagged by hallucination audit. Review before external use.</p>
  <ul>
    {% for f in brief.audit_flags %}
    <li><code>{{ f.location }}</code>: {{ f.claim_text[:80] }}… <em>({{ f.recommended_action }})</em></li>
    {% endfor %}
  </ul>
</blockquote>
{% endif %}

<p class="disclosure">{{ brief.disclosure }}</p>

{% if debug is defined %}
<div class="debug-section">
  <details>
    <summary>Pipeline Debug Log</summary>
    <p class="debug-meta">Run ID: {{ debug.run_id }}</p>
    <p class="debug-meta">Timestamp: {{ debug.timestamp }}</p>
    <p class="debug-meta">Depth: {{ debug.depth }}</p>

    <p class="debug-meta"><strong>Token Usage</strong></p>
    {% if debug.token_rows %}
    <table>
      <thead>
        <tr>
          <th>Stage</th>
          <th>Model</th>
          <th>Tokens In</th>
          <th>Tokens Out</th>
          <th>Est. Cost</th>
        </tr>
      </thead>
      <tbody>
        {% for row in debug.token_rows %}
        <tr>
          <td>{{ row.stage }}</td>
          <td>{{ row.model }}</td>
          <td>{{ "{:,}".format(row.tokens_input) }}</td>
          <td>{{ "{:,}".format(row.tokens_output) }}</td>
          <td>${{ "%.4f"|format(row.cost) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="debug-empty">No API calls this run.</p>
    {% endif %}

    {% if debug.warn_lines %}
    <p class="debug-meta"><strong>Warnings &amp; Errors</strong></p>
    <ul class="debug-warn">
      {% for line in debug.warn_lines %}
      <li>{{ line | e }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </details>
</div>
{% endif %}

</body>
</html>
